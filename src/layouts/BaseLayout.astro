---
import '../styles/global.css';
import '../styles/anim.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'StackTrace — interactive system design and DSA visualizations.' } = Astro.props;
const path = Astro.url.pathname;
const isRoadmap = path === '/roadmap/' || path === '/roadmap';
const isNotes = path === '/notes/' || path.startsWith('/learn/notes');
const isDsa = path === '/dsa/' || path.startsWith('/learn/dsa');
const isAnim = path.startsWith('/animations');
const isAccount = path.startsWith('/account') || path.startsWith('/login');
const isAdmin = path.startsWith('/admin');
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__brand" href="/" aria-label="StackTrace — home">
          <img src="/logo.svg" alt="" class="site-header__logo" width="28" height="28" />
          <span class="site-header__wordmark">
            <span class="site-header__wordmark-stack">Stack</span><span class="site-header__wordmark-trace">Trace</span>
          </span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          <a href="/roadmap/" aria-current={isRoadmap ? 'page' : undefined}>Roadmap</a>
          <a href="/notes/" aria-current={isNotes ? 'page' : undefined}>System Design</a>
          <a href="/dsa/" aria-current={isDsa ? 'page' : undefined}>DSA</a>
          <a href="/animations/" aria-current={isAnim ? 'page' : undefined}>Animations</a>
          <a
            id="nav-admin"
            href="/admin/"
            aria-current={isAdmin ? 'page' : undefined}
            hidden
          >Admin</a>
        </nav>

        <form
          class="header-search"
          role="search"
          data-empty="true"
          data-focused="false"
          aria-label="Search the site"
          onsubmit="return false"
        >
          <svg
            class="header-search__icon"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-3.5-3.5" />
          </svg>
          <input
            id="site-search-input"
            class="header-search__input"
            type="search"
            placeholder="Search notes, animations…"
            autocomplete="off"
            spellcheck="false"
            aria-controls="site-search-drawer"
            aria-autocomplete="list"
          />
          <kbd class="header-search__kbd" aria-hidden="true">/</kbd>
          <div
            id="site-search-drawer"
            class="header-search__drawer"
            role="listbox"
            aria-label="Search results"
            hidden
          ></div>
        </form>

        <div class="site-header__tools">
          <button
            id="search-toggle"
            class="site-header__icon-btn"
            type="button"
            aria-label="Open search"
            aria-expanded="false"
            aria-controls="site-search-input"
          >
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7" />
              <path d="m20 20-3.5-3.5" />
            </svg>
          </button>
          <button id="theme-toggle" class="site-header__icon-btn" type="button" aria-label="Toggle color theme">
            <svg id="theme-icon-dark" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
            </svg>
          </button>
          <a
            id="nav-account"
            class="site-header__signin"
            href="/account/"
            aria-current={isAccount ? 'page' : undefined}
          >Sign in</a>
        </div>
      </div>
    </header>

    <main id="main" class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        <strong>StackTrace</strong> · built with <span class="site-footer__heart" aria-label="love">♥</span>
      </p>
    </footer>

    <script>
      // ============================================================
      // Theme toggle — dark / light, persisted in localStorage.
      // Icon swap: moon ↔ sun.
      // ============================================================
      const SUN_PATH = 'M12 3v2M12 19v2M5 12H3M21 12h-2M18.36 5.64l-1.41 1.41M7.05 16.95l-1.41 1.41M18.36 18.36l-1.41-1.41M7.05 7.05 5.64 5.64';
      const MOON_PATH = 'M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z';

      const stored = localStorage.getItem('theme');
      const initial = stored ?? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      document.documentElement.setAttribute('data-theme', initial);

      function setThemeIcon(theme: string): void {
        const icon = document.getElementById('theme-icon-dark') as unknown as SVGElement | null;
        if (!icon) return;
        const path = icon.querySelector('path');
        const circle = icon.querySelector('circle');
        if (!path) return;
        if (theme === 'light') {
          path.setAttribute('d', SUN_PATH);
          if (!circle) {
            const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            c.setAttribute('cx', '12'); c.setAttribute('cy', '12'); c.setAttribute('r', '4');
            icon.appendChild(c);
          }
        } else {
          path.setAttribute('d', MOON_PATH);
          if (circle) circle.remove();
        }
      }
      setThemeIcon(initial);

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        setThemeIcon(next);
      });

      // ============================================================
      // Auth hint cookie — middleware mirrors the session into a
      // non-HttpOnly cookie just so prerendered pages can swap the
      // "Sign in" label to the user's name without an SSR round trip.
      // ============================================================
      const cookies = Object.fromEntries(
        document.cookie.split(';').map((c) => {
          const idx = c.indexOf('=');
          return [c.slice(0, idx).trim(), decodeURIComponent(c.slice(idx + 1))];
        }),
      );
      const hint = cookies['stacktrace_signed_in'] ?? cookies['sysviz_signed_in'];
      if (hint) {
        const [name, role] = hint.split('|');
        const acct = document.getElementById('nav-account');
        if (acct) {
          acct.textContent = name || 'Account';
          acct.setAttribute('href', '/account/');
        }
        if (role === 'admin') {
          const admin = document.getElementById('nav-admin');
          if (admin) admin.removeAttribute('hidden');
        }
      }

      // ============================================================
      // Custom search — uses a plain <input> we fully own, dispatches
      // queries to Pagefind's JS API and renders results into our own
      // drawer. No third-party UI is mounted, so no CSS surprises.
      //
      // In dev mode the /pagefind/pagefind.js bundle doesn't exist
      // (it's generated by `pagefind --site dist` during `npm run build`),
      // so the import quietly fails and the input simply doesn't filter.
      // ============================================================
      type PagefindModule = {
        init: () => Promise<void>;
        search: (q: string) => Promise<{ results: Array<{ data: () => Promise<PagefindResult> }> }>;
      };
      type PagefindSubResult = {
        title?: string;
        url: string;
        excerpt: string;
      };
      type PagefindResult = {
        url: string;
        meta: { title?: string };
        excerpt: string;
        sub_results?: PagefindSubResult[];
      };
      type RenderItem = {
        section: string;
        title: string;
        url: string;
        excerpt: string;
        subResults: PagefindSubResult[];
      };

      const searchForm = document.querySelector<HTMLFormElement>('.header-search');
      const searchInput = document.getElementById('site-search-input') as HTMLInputElement | null;
      const searchDrawer = document.getElementById('site-search-drawer') as HTMLElement | null;
      const searchToggle = document.getElementById('search-toggle');
      const headerEl = document.querySelector<HTMLElement>('.site-header');

      let pagefind: PagefindModule | null = null;
      let pagefindLoading: Promise<PagefindModule | null> | null = null;

      async function loadPagefind(): Promise<PagefindModule | null> {
        if (pagefind) return pagefind;
        if (pagefindLoading) return pagefindLoading;
        pagefindLoading = (async () => {
          try {
            // The path is held in a variable so Vite's import-analysis pass
            // doesn't try to resolve `/pagefind/pagefind.js` at build time —
            // it only exists in the post-build `dist/` tree, generated by
            // `pagefind --site dist`. In dev it never resolves, but the
            // catch below turns the failure into a "no results" hint.
            const href = ['', 'pagefind', 'pagefind.js'].join('/');
            // @ts-ignore — runtime-loaded module has no TS typings.
            const mod = await import(/* @vite-ignore */ href);
            await mod.init?.();
            pagefind = mod as PagefindModule;
            return pagefind;
          } catch {
            return null;
          }
        })();
        return pagefindLoading;
      }

      function syncSearchState(): void {
        if (!searchForm || !searchInput) return;
        searchForm.dataset.empty = searchInput.value ? 'false' : 'true';
        searchForm.dataset.focused = document.activeElement === searchInput ? 'true' : 'false';
      }

      function sectionForUrl(url: string): string {
        if (url.startsWith('/learn/notes/')) return 'Note';
        if (url.startsWith('/learn/dsa/')) return 'DSA';
        if (url.startsWith('/dsa/')) return 'DSA';
        if (url.startsWith('/notes/')) return 'System Design';
        if (url.startsWith('/animations/')) return 'Animation';
        if (url.startsWith('/account/')) return 'Account';
        if (url.startsWith('/admin/')) return 'Admin';
        if (url.startsWith('/roadmap')) return 'Roadmap';
        if (url.startsWith('/pricing')) return 'Pricing';
        return 'Page';
      }

      function lockBodyScroll(lock: boolean): void {
        document.body.style.overflow = lock ? 'hidden' : '';
      }

      function setDrawerVisible(visible: boolean): void {
        if (!searchDrawer) return;
        searchDrawer.hidden = !visible;
        lockBodyScroll(visible);
      }

      function renderResults(items: RenderItem[]): void {
        if (!searchDrawer) return;
        if (items.length === 0) {
          searchDrawer.innerHTML = '';
          setDrawerVisible(false);
          return;
        }
        setDrawerVisible(true);
        // Group by section for brain-detox-style headers.
        const groups = new Map<string, RenderItem[]>();
        for (const item of items) {
          const arr = groups.get(item.section) ?? [];
          arr.push(item);
          groups.set(item.section, arr);
        }
        const html: string[] = [];
        html.push(`<div class="header-search__summary">${items.length} result${items.length === 1 ? '' : 's'}</div>`);
        for (const [section, rows] of groups.entries()) {
          html.push(`<div class="header-search__group">
            <div class="header-search__group-label">${section}</div>`);
          for (const r of rows) {
            html.push(`
              <a class="header-search__result" href="${r.url}">
                <span class="header-search__result-title">${r.title}</span>
                <span class="header-search__result-url">${r.url}</span>
                <span class="header-search__result-excerpt">${r.excerpt}</span>
              </a>`);
            for (const sub of r.subResults.slice(0, 2)) {
              html.push(`
                <a class="header-search__result header-search__result--sub" href="${sub.url}">
                  <span class="header-search__result-subicon" aria-hidden="true">↳</span>
                  <span class="header-search__result-subbody">
                    <span class="header-search__result-title">${sub.title ?? sub.url}</span>
                    <span class="header-search__result-excerpt">${sub.excerpt}</span>
                  </span>
                </a>`);
            }
          }
          html.push('</div>');
        }
        searchDrawer.innerHTML = html.join('');
      }

      function showEmptyHint(message: string): void {
        if (!searchDrawer) return;
        searchDrawer.innerHTML = `<p class="header-search__hint">${message}</p>`;
        setDrawerVisible(true);
      }

      function showNoResults(query: string): void {
        if (!searchDrawer) return;
        searchDrawer.innerHTML = `<p class="header-search__hint">No matches for <code>${query.replace(/[<>&]/g, '')}</code>. Try a shorter or different query.</p>`;
        setDrawerVisible(true);
      }

      let searchDebounce: ReturnType<typeof setTimeout> | null = null;
      async function runSearch(query: string): Promise<void> {
        const q = query.trim();
        if (!q) {
          renderResults([]);
          return;
        }
        const pf = await loadPagefind();
        if (!pf) {
          showEmptyHint('Search index is built at <code>npm run build</code> time. Live in production.');
          return;
        }
        const { results } = await pf.search(q);
        if (results.length === 0) {
          showNoResults(q);
          return;
        }
        const top = results.slice(0, 10);
        const data = await Promise.all(top.map((r) => r.data()));
        renderResults(
          data.map((d) => ({
            section: sectionForUrl(d.url),
            title: d.meta?.title ?? d.url,
            url: d.url,
            excerpt: d.excerpt,
            subResults: d.sub_results ?? [],
          })),
        );
      }

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          syncSearchState();
          if (searchDebounce) clearTimeout(searchDebounce);
          searchDebounce = setTimeout(() => void runSearch(searchInput.value), 180);
        });
        searchInput.addEventListener('focus', () => {
          syncSearchState();
          if (searchInput.value) void runSearch(searchInput.value);
        });
        searchInput.addEventListener('blur', () => {
          // Defer so a click on a result still navigates.
          setTimeout(() => {
            if (searchDrawer && document.activeElement !== searchInput && !searchDrawer.contains(document.activeElement)) {
              setDrawerVisible(false);
            }
            syncSearchState();
          }, 150);
        });
      }

      // Global keyboard shortcuts: `/` and Cmd/Ctrl+K focus the input,
      // Esc clears and blurs. Matches brain-detox / MkDocs Material UX.
      document.addEventListener('keydown', (e) => {
        const target = e.target as HTMLElement | null;
        const isTyping = !!target && (
          target.tagName === 'INPUT' ||
          target.tagName === 'TEXTAREA' ||
          target.isContentEditable
        );
        if ((e.key === '/' && !isTyping) || ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k')) {
          e.preventDefault();
          searchInput?.focus();
          searchInput?.select();
        } else if (e.key === 'Escape' && searchInput) {
          const drawerOpen = searchDrawer && !searchDrawer.hidden;
          if (document.activeElement === searchInput || drawerOpen) {
            searchInput.value = '';
            renderResults([]);
            searchInput.blur();
            syncSearchState();
          }
        }
      });

      // Click-outside-to-close
      document.addEventListener('click', (e) => {
        if (!searchForm) return;
        if (!searchForm.contains(e.target as Node)) {
          setDrawerVisible(false);
        }
      });

      // Mobile search toggle: collapses the input behind a 🔍 icon
      // on narrow viewports; tap reveals it as a second row.
      searchToggle?.addEventListener('click', () => {
        if (!headerEl) return;
        const open = headerEl.getAttribute('data-search-open') === 'true';
        const next = !open;
        headerEl.setAttribute('data-search-open', next ? 'true' : 'false');
        searchToggle.setAttribute('aria-expanded', next ? 'true' : 'false');
        if (next) searchInput?.focus();
      });
    </script>

    <style is:global>
      /* Footer */
      .site-footer {
        margin-top: 4rem;
        padding: 1.25rem clamp(1rem, 3vw, 2.25rem);
        border-top: 1px solid color-mix(in srgb, var(--card-border) 60%, transparent);
        text-align: center;
        color: var(--fg-muted);
        font-size: 0.85rem;
      }
      .site-footer p { margin: 0; }
      .site-footer__heart {
        color: #ef4444;
        display: inline-block;
        font-size: 0.95rem;
        animation: site-footer-heart 1.6s ease-in-out infinite;
      }
      @keyframes site-footer-heart {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.18); }
      }
      @media (prefers-reduced-motion: reduce) {
        .site-footer__heart { animation: none; }
      }

      /* Skip link (keyboard a11y) */
      .skip-link {
        position: absolute;
        top: -3rem;
        left: 1rem;
        padding: 0.5rem 0.85rem;
        background: var(--card-bg);
        border: 1px solid var(--accent);
        border-radius: 8px;
        color: var(--fg);
        font-weight: 600;
        z-index: 999;
        text-decoration: none;
      }
      .skip-link:focus { top: 0.75rem; }

      /* Sticky frosted-glass header */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        background: color-mix(in srgb, var(--bg) 78%, transparent);
        border-bottom: 1px solid color-mix(in srgb, var(--card-border) 60%, transparent);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        width: 100%;
        padding: 0.55rem clamp(1rem, 3vw, 2.25rem);
        min-height: 56px;
      }

      /* Brand */
      .site-header__brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
        color: var(--fg);
        font-weight: 700;
        flex: 0 0 auto;
        padding: 0.2rem 0.35rem;
        border-radius: 8px;
        transition: background 0.15s ease;
      }
      .site-header__brand:hover {
        background: color-mix(in srgb, var(--accent) 8%, transparent);
      }
      .site-header__logo {
        width: 28px;
        height: 28px;
        flex: 0 0 auto;
      }
      .site-header__wordmark {
        font-size: 1.1rem;
        letter-spacing: -0.015em;
        font-weight: 800;
        display: inline-flex;
        align-items: baseline;
      }
      .site-header__wordmark-stack {
        color: var(--fg);
      }
      .site-header__wordmark-trace {
        background: var(--grad-3);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      /* Nav — inline, tight tabs */
      .site-nav {
        display: flex;
        align-items: center;
        gap: 0.1rem;
        flex: 0 0 auto;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .site-nav::-webkit-scrollbar { display: none; }
      .site-nav a {
        position: relative;
        padding: 0.45rem 0.75rem;
        border-radius: 7px;
        color: var(--fg-muted);
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.15s ease, background 0.15s ease;
      }
      .site-nav a:hover {
        color: var(--fg);
        background: color-mix(in srgb, var(--accent) 8%, transparent);
      }
      .site-nav a[aria-current='page'] {
        color: var(--accent);
        font-weight: 600;
      }
      .site-nav a[aria-current='page']::after {
        content: '';
        position: absolute;
        left: 0.75rem;
        right: 0.75rem;
        bottom: -0.4rem;
        height: 2px;
        background: var(--accent);
        border-radius: 2px;
      }

      /* Custom search — fully owns its DOM, no third-party CSS to fight */
      .header-search {
        position: relative;
        display: flex;
        align-items: center;
        flex: 1 1 auto;
        max-width: 420px;
        min-width: 0;
        margin-left: auto;
      }
      .header-search__icon {
        position: absolute;
        left: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--fg-faint);
        pointer-events: none;
        z-index: 2;
        transition: color 0.15s ease;
      }
      .header-search[data-focused='true'] .header-search__icon {
        color: var(--accent);
      }
      .header-search__input {
        width: 100%;
        height: 38px;
        padding: 0 2.4rem 0 2.5rem;
        font-size: 0.88rem;
        background: color-mix(in srgb, var(--bg-soft) 75%, transparent);
        border: 1px solid color-mix(in srgb, var(--card-border) 65%, transparent);
        border-radius: 10px;
        color: var(--fg);
        font-family: var(--font-text);
        outline: none;
        transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
        appearance: none;
        -webkit-appearance: none;
      }
      .header-search__input::placeholder { color: var(--fg-faint); }
      .header-search__input::-webkit-search-cancel-button { display: none; }
      .header-search__input:hover {
        background: var(--bg-soft);
        border-color: color-mix(in srgb, var(--accent) 30%, var(--card-border));
      }
      .header-search__input:focus {
        background: var(--card-bg);
        border-color: var(--accent);
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 18%, transparent);
      }
      .header-search__kbd {
        position: absolute;
        right: 0.6rem;
        top: 50%;
        transform: translateY(-50%);
        padding: 0.1rem 0.4rem;
        background: color-mix(in srgb, var(--card-border) 60%, transparent);
        border: 1px solid color-mix(in srgb, var(--card-border) 80%, transparent);
        border-radius: 5px;
        color: var(--fg-faint);
        font-family: var(--font-code);
        font-size: 0.7rem;
        font-weight: 600;
        line-height: 1;
        pointer-events: none;
        z-index: 2;
        transition: opacity 0.15s ease;
      }
      .header-search[data-focused='true'] .header-search__kbd,
      .header-search[data-empty='false'] .header-search__kbd {
        opacity: 0;
      }
      .header-search__drawer {
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 0;
        right: 0;
        width: min(640px, calc(100vw - 1.5rem));
        max-height: min(70vh, 540px);
        overflow-y: auto;
        overscroll-behavior: contain;
        background: var(--bg);
        border: 1px solid var(--card-border);
        border-radius: 14px;
        box-shadow:
          0 1px 2px rgba(0, 0, 0, 0.4),
          0 24px 70px rgba(0, 0, 0, 0.45);
        padding: 0;
        z-index: 60;
      }
      /* Dedicated thin scrollbar for the results panel only */
      .header-search__drawer::-webkit-scrollbar { width: 6px; }
      .header-search__drawer::-webkit-scrollbar-track { background: transparent; }
      .header-search__drawer::-webkit-scrollbar-thumb {
        background: color-mix(in srgb, var(--fg-muted) 45%, transparent);
        border-radius: 3px;
      }
      .header-search__drawer::-webkit-scrollbar-thumb:hover {
        background: color-mix(in srgb, var(--fg-muted) 70%, transparent);
      }
      .header-search__drawer {
        scrollbar-width: thin;
        scrollbar-color: color-mix(in srgb, var(--fg-muted) 45%, transparent) transparent;
      }

      /* Top summary bar — "N results" */
      .header-search__summary {
        padding: 0.55rem 0.85rem;
        font-family: var(--font-code);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--fg-muted);
        background: color-mix(in srgb, var(--accent) 6%, transparent);
        border-bottom: 1px solid var(--card-border);
        position: sticky;
        top: 0;
        z-index: 2;
      }

      /* Group: section header + its rows. Matches brain-detox's
         `.md-search-result__meta` chip-style label. */
      .header-search__group + .header-search__group {
        border-top: 1px solid color-mix(in srgb, var(--card-border) 60%, transparent);
      }
      .header-search__group-label {
        padding: 0.5rem 0.85rem 0.35rem;
        font-family: var(--font-code);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        background: color-mix(in srgb, var(--accent) 8%, transparent);
      }

      .header-search__result {
        display: block;
        padding: 0.7rem 0.85rem;
        border-bottom: 1px solid color-mix(in srgb, var(--card-border) 40%, transparent);
        color: var(--fg);
        text-decoration: none;
        transition: background 0.12s ease;
      }
      .header-search__group :last-child.header-search__result { border-bottom: none; }
      .header-search__result:hover,
      .header-search__result:focus {
        background: color-mix(in srgb, var(--accent) 8%, transparent);
        outline: none;
      }
      .header-search__result-title {
        display: block;
        font-weight: 600;
        font-size: 0.93rem;
        color: var(--fg);
        line-height: 1.3;
      }
      .header-search__result-url {
        display: block;
        font-family: var(--font-code);
        font-size: 0.7rem;
        color: var(--fg-faint);
        margin-top: 0.15rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .header-search__result-excerpt {
        display: block;
        font-size: 0.83rem;
        color: var(--fg-muted);
        margin-top: 0.3rem;
        line-height: 1.45;
      }
      .header-search__result-excerpt :global(mark) {
        background: color-mix(in srgb, var(--accent) 30%, transparent);
        color: var(--fg);
        padding: 0 0.15rem;
        border-radius: 3px;
        font-weight: 600;
      }

      /* Sub-result: heading-anchored match inside the same page */
      .header-search__result--sub {
        display: grid;
        grid-template-columns: 1.5rem 1fr;
        gap: 0.15rem;
        padding: 0.55rem 0.85rem 0.55rem 1.65rem;
        background: color-mix(in srgb, var(--bg-soft) 35%, transparent);
      }
      .header-search__result-subicon {
        color: var(--fg-faint);
        font-family: var(--font-code);
        font-size: 0.9rem;
        line-height: 1.3;
      }
      .header-search__result-subbody { display: block; }
      .header-search__result--sub .header-search__result-title {
        font-size: 0.86rem;
        font-weight: 500;
      }

      .header-search__hint {
        margin: 0;
        padding: 1rem 0.95rem;
        color: var(--fg-muted);
        font-size: 0.88rem;
        line-height: 1.5;
      }
      .header-search__hint code {
        font-family: var(--font-code);
        background: var(--bg-soft);
        padding: 0.05rem 0.35rem;
        border-radius: 4px;
        font-size: 0.78rem;
        color: var(--fg);
      }

      /* Tools — icon ghost buttons + sign-in chip on the far right */
      .site-header__tools {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        flex: 0 0 auto;
      }
      .site-header__icon-btn {
        appearance: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        padding: 0;
        border: 1px solid transparent;
        background: transparent;
        color: var(--fg-muted);
        border-radius: 8px;
        cursor: pointer;
        text-decoration: none;
        transition: color 0.15s ease, background 0.15s ease, transform 0.08s ease;
      }
      .site-header__icon-btn:hover {
        color: var(--fg);
        background: color-mix(in srgb, var(--accent) 10%, transparent);
      }
      .site-header__icon-btn:active { transform: scale(0.94); }
      .site-header__icon-btn:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      #search-toggle { display: none; }

      .site-header__signin {
        display: inline-flex;
        align-items: center;
        padding: 0 0.85rem;
        height: 36px;
        border-radius: 8px;
        border: 1px solid color-mix(in srgb, var(--accent) 50%, var(--card-border));
        color: var(--accent);
        background: transparent;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
        margin-left: 0.3rem;
        transition: background 0.15s ease, color 0.15s ease, transform 0.08s ease;
      }
      .site-header__signin:hover {
        background: color-mix(in srgb, var(--accent) 12%, transparent);
      }
      .site-header__signin:active { transform: scale(0.97); }

      /* Wide tablets / small desktops (1024 → 1180px) — shrink search */
      @media (max-width: 1180px) {
        .site-header__inner { gap: 0.85rem; }
        .header-search { max-width: 320px; }
      }

      /* Narrow tablets (768 → 1023px) — hide kbd hint, tighten nav,
         keep one row but shrink everything */
      @media (max-width: 1023px) {
        .header-search { max-width: 240px; }
        .header-search__kbd { display: none; }
        .site-nav a { padding: 0.45rem 0.55rem; font-size: 0.83rem; }
        .site-header__inner { gap: 0.6rem; }
        .site-header__wordmark { font-size: 1rem; }
      }

      /* Below 880px — start collapsing: hide wordmark, keep just the logo */
      @media (max-width: 880px) {
        .site-header__wordmark { display: none; }
      }

      /* Mobile — two clean rows: brand+tools on row 1, nav on row 2.
         Search slides in as row 3 when the 🔍 icon is tapped. */
      @media (max-width: 767px) {
        #search-toggle { display: inline-flex; }
        .header-search { display: none; }
        .site-header__inner {
          flex-wrap: wrap;
          gap: 0.5rem 0.25rem;
          padding: 0.55rem 1rem 0.2rem;
          min-height: 52px;
        }
        .site-header__brand {
          margin-right: auto;
          padding: 0.15rem 0.3rem;
        }
        .site-header__logo { width: 26px; height: 26px; }
        .site-header__wordmark {
          display: inline-flex;
          font-size: 1rem;
        }
        .site-header__signin { display: none; }
        .site-header__tools { gap: 0.15rem; }
        .site-header__icon-btn { width: 40px; height: 40px; border-radius: 9px; }
        .site-header__icon-btn svg { width: 19px; height: 19px; }

        /* Search row — appears below the brand when toggled open */
        .site-header[data-search-open='true'] .header-search {
          display: flex;
          order: 50;
          flex-basis: 100%;
          max-width: none;
          margin: 0.25rem 0 0;
        }
        .site-header[data-search-open='true'] .header-search__input { height: 42px; }

        /* Nav row — full-width, sits below row 1 with a hairline divider */
        .site-nav {
          order: 60;
          flex-basis: 100%;
          margin: 0.25rem -1rem 0;
          padding: 0.2rem 1rem 0.35rem;
          border-top: 1px solid color-mix(in srgb, var(--card-border) 50%, transparent);
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
        }
        .site-nav a {
          padding: 0.55rem 0.7rem;
          font-size: 0.86rem;
          font-weight: 500;
        }
        .site-nav a[aria-current='page']::after {
          bottom: -0.3rem;
          height: 2px;
        }
      }

      /* Very narrow — tighten further, shrink wordmark */
      @media (max-width: 420px) {
        .site-header__inner { padding: 0.45rem 0.75rem 0.15rem; gap: 0.25rem; }
        .site-header__wordmark { font-size: 0.92rem; }
        .site-header__logo { width: 24px; height: 24px; }
        .site-header__icon-btn { width: 38px; height: 38px; }
        .site-nav { margin: 0.2rem -0.75rem 0; padding: 0.15rem 0.75rem 0.3rem; }
        .site-nav a { padding: 0.45rem 0.55rem; font-size: 0.82rem; }
      }
    </style>
  </body>
</html>
