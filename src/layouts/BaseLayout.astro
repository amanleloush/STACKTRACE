---
import '../styles/global.css';
import '../styles/anim.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Interactive system-design and DSA visualizations.' } = Astro.props;
const path = Astro.url.pathname;
const isRoadmap = path === '/roadmap/' || path === '/roadmap';
const isNotes = path === '/notes/' || path.startsWith('/learn/notes');
const isDsa = path === '/dsa/' || path.startsWith('/learn/dsa');
const isAnim = path.startsWith('/animations');
const isAbout = path.startsWith('/about');
const isAccount = path.startsWith('/account') || path.startsWith('/login');
const isAdmin = path.startsWith('/admin');

// We can't safely read Astro.locals.user here — Astro's static analyzer
// treats ANY `Astro.locals.*` access in a layout used by prerendered
// pages as a cookie/header-touch and emits the
// "Astro.request.headers was used" warning at build time. So the header
// stays auth-agnostic at SSR; client-side script below upgrades the
// "Sign in" label to the user's name when a non-HttpOnly indicator
// cookie is present.
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <a class="site-header__brand" href="/">sysviz</a>
      <nav class="site-nav" aria-label="Primary">
        <a href="/roadmap/" aria-current={isRoadmap ? 'page' : undefined}>Roadmap</a>
        <a href="/notes/" aria-current={isNotes ? 'page' : undefined}>Notes</a>
        <a href="/dsa/" aria-current={isDsa ? 'page' : undefined}>DSA</a>
        <a href="/animations/" aria-current={isAnim ? 'page' : undefined}>Animations</a>
        <a href="/about/" aria-current={isAbout ? 'page' : undefined}>About</a>
        <a
          id="nav-admin"
          href="/admin/"
          aria-current={isAdmin ? 'page' : undefined}
          hidden
        >Admin</a>
        <a
          id="nav-account"
          href="/account/"
          aria-current={isAccount ? 'page' : undefined}
        >Sign in</a>
        <button id="theme-toggle" class="anim__btn" aria-label="Toggle color theme">☾</button>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>Built with Astro. Working title — final name TBD.</p>
    </footer>

    <script>
      // Theme persistence + toggle
      const stored = localStorage.getItem('theme');
      const initial = stored ?? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      document.documentElement.setAttribute('data-theme', initial);
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        if (btn) btn.textContent = next === 'dark' ? '☾' : '☀';
      });
      if (btn) btn.textContent = initial === 'dark' ? '☾' : '☀';

      // Auth-state hint: middleware sets a sysviz_signed_in cookie on login
      // (non-HttpOnly mirror of the session — no privileges, just a UI hint).
      // Use it to swap the "Sign in" label for "Account" / show the Admin link.
      const cookies = Object.fromEntries(
        document.cookie.split(';').map((c) => {
          const idx = c.indexOf('=');
          return [c.slice(0, idx).trim(), decodeURIComponent(c.slice(idx + 1))];
        }),
      );
      const hint = cookies['sysviz_signed_in'];
      if (hint) {
        const [name, role] = hint.split('|');
        const acct = document.getElementById('nav-account');
        if (acct) {
          acct.textContent = name || 'Account';
          acct.setAttribute('href', '/account/');
        }
        if (role === 'admin') {
          const admin = document.getElementById('nav-admin');
          if (admin) admin.removeAttribute('hidden');
        }
      }
    </script>
  </body>
</html>
