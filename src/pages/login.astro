---
import BaseLayout from '~/layouts/BaseLayout.astro';

export const prerender = false;

const next = Astro.url.searchParams.get('next') ?? '/account/';
const errorParam = Astro.url.searchParams.get('error');

const googleClientId =
  import.meta.env.GOOGLE_CLIENT_ID ??
  (typeof process !== 'undefined' ? process.env.GOOGLE_CLIENT_ID : undefined);
const googleConfigured = !!(googleClientId && googleClientId.length > 0);

const devBackdoorOn =
  import.meta.env.DEV &&
  (import.meta.env.DEV_AUTH_BACKDOOR === '1' ||
    (typeof process !== 'undefined' && process.env.DEV_AUTH_BACKDOOR === '1'));
---
<BaseLayout title="Sign in — sysviz">
  <section class="login">
    <h1>Sign in</h1>
    <p class="login__sub">
      Sign in to bookmark progress, save annotations, and (once Phase 4 lands) unlock premium content.
    </p>

    {errorParam === 'oauth-misconfig' && (
      <div class="login__alert">
        <strong>Google OAuth isn't configured.</strong>{' '}
        {devBackdoorOn
          ? 'Use the dev login below — it skips Google entirely.'
          : 'Set GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET in .env.local, OR restart the dev server with DEV_AUTH_BACKDOOR=1 to enable the backdoor sign-in.'}
      </div>
    )}

    {googleConfigured ? (
      <a
        class="anim__btn anim__btn--primary login__btn"
        href={`/api/auth/google/start?next=${encodeURIComponent(next)}`}
      >
        Continue with Google
      </a>
    ) : (
      <div class="login__google-hint">
        <span class="login__chip">Not configured</span>
        Google sign-in is disabled until <code>GOOGLE_CLIENT_ID</code> + <code>GOOGLE_CLIENT_SECRET</code>
        are set in <code>.env.local</code>.
      </div>
    )}

    {devBackdoorOn ? (
      <div class={`login__dev ${!googleConfigured ? 'login__dev--primary' : ''}`}>
        <div class="login__dev-head">
          <strong>Dev sign-in</strong>
          <span class="login__chip login__chip--accent">DEV_AUTH_BACKDOOR=1</span>
        </div>
        <p>
          Mints a session against any email without going through Google. Refuses to run in production.
          {' '}Emails in <code>ADMIN_EMAILS</code> auto-promote to role&nbsp;=&nbsp;admin on first sign-in.
        </p>
        <form action="/api/auth/dev-login" method="get">
          <input type="hidden" name="next" value={next} />
          <label>
            email
            <input type="email" name="email" required placeholder="admin@example.com" autocomplete="off" />
          </label>
          <button
            type="submit"
            class={`anim__btn ${!googleConfigured ? 'anim__btn--primary' : ''}`}
          >
            Sign in
          </button>
        </form>
      </div>
    ) : (
      <div class="login__dev-hint">
        <strong>Tip for local dev:</strong> restart the server with
        {' '}<code>DEV_AUTH_BACKDOOR=1 npm run dev</code> to skip Google and sign in with any email.
        Set <code>ADMIN_EMAILS=you@example.com</code> on the same line to flip into admin on first login.
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .login { max-width: 28rem; margin: 4rem auto; }
  h1 { text-align: center; }
  .login__sub {
    color: var(--fg-muted);
    text-align: center;
    margin-bottom: 2rem;
    line-height: 1.55;
  }
  .login__alert {
    padding: 0.8rem 1rem;
    background: color-mix(in srgb, var(--anim-danger) 12%, transparent);
    border: 1px solid var(--anim-danger);
    border-radius: 10px;
    margin-bottom: 1.5rem;
    font-size: 0.88rem;
    line-height: 1.5;
  }
  .login__btn {
    display: block;
    width: 100%;
    padding: 0.8rem 1.5rem;
    text-align: center;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .login__google-hint, .login__dev-hint {
    padding: 0.9rem 1rem;
    background: var(--card-bg);
    border: 1px dashed var(--card-border);
    border-radius: 10px;
    font-size: 0.85rem;
    color: var(--fg-muted);
    line-height: 1.55;
    margin-bottom: 1.25rem;
  }
  .login__google-hint code, .login__dev-hint code, .login__dev p code {
    background: var(--code-bg);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.88em;
  }
  .login__chip {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
    background: var(--card-border);
    color: var(--fg-muted);
    margin-right: 0.5rem;
  }
  .login__chip--accent {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
  }
  .login__dev {
    padding: 1rem 1.1rem 1.2rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    margin-top: 0.5rem;
  }
  .login__dev--primary {
    border-color: var(--primary-light);
    background: color-mix(in srgb, var(--primary) 6%, var(--card-bg));
  }
  .login__dev-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.6rem;
  }
  .login__dev p {
    color: var(--fg-muted);
    font-size: 0.85rem;
    line-height: 1.55;
    margin: 0 0 1rem;
  }
  .login__dev form {
    display: flex;
    gap: 0.5rem;
    align-items: end;
  }
  .login__dev label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    font-size: 0.75rem;
    color: var(--fg-faint);
  }
  .login__dev input {
    padding: 0.55rem 0.7rem;
    border-radius: 7px;
    border: 1px solid var(--card-border);
    background: var(--bg-soft);
    color: var(--fg);
    font: inherit;
  }
</style>
