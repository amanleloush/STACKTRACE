---
import BaseLayout from '~/layouts/BaseLayout.astro';

export const prerender = false;

const next = Astro.url.searchParams.get('next') ?? '/account/';
const devBackdoorOn =
  import.meta.env.DEV &&
  (import.meta.env.DEV_AUTH_BACKDOOR === '1' ||
    (typeof process !== 'undefined' && process.env.DEV_AUTH_BACKDOOR === '1'));
---
<BaseLayout title="Sign in — sysviz">
  <section class="login">
    <h1>Sign in</h1>
    <p class="login__sub">
      Sign in to bookmark progress, save annotations, and (later) unlock premium content.
      All you need is a Google account.
    </p>
    <a class="anim__btn anim__btn--primary login__btn"
       href={`/api/auth/google/start?next=${encodeURIComponent(next)}`}>
      Continue with Google
    </a>

    {devBackdoorOn && (
      <details class="login__dev">
        <summary>Dev login (DEV_AUTH_BACKDOOR=1)</summary>
        <form action="/api/auth/dev-login" method="get">
          <input type="hidden" name="next" value={next} />
          <label>
            email
            <input type="email" name="email" required placeholder="admin@example.com" />
          </label>
          <button type="submit" class="anim__btn">Sign in as user</button>
        </form>
      </details>
    )}
  </section>
</BaseLayout>

<style>
  .login { max-width: 26rem; margin: 4rem auto; text-align: center; }
  .login__sub { color: var(--fg-muted); margin-bottom: 2rem; line-height: 1.55; }
  .login__btn { padding: 0.7rem 1.5rem; font-size: 0.95rem; }
  .login__dev {
    margin-top: 3rem;
    padding: 1rem;
    background: var(--card-bg);
    border: 1px dashed var(--card-border);
    border-radius: 12px;
    text-align: left;
    font-size: 0.85rem;
  }
  .login__dev summary { cursor: pointer; color: var(--fg-muted); }
  .login__dev form { display: flex; gap: 0.5rem; align-items: end; margin-top: 1rem; }
  .login__dev label { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; font-size: 0.75rem; color: var(--fg-faint); }
  .login__dev input {
    padding: 0.5rem 0.7rem;
    border-radius: 7px;
    border: 1px solid var(--card-border);
    background: var(--bg-soft);
    color: var(--fg);
    font: inherit;
  }
</style>
