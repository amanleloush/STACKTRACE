---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroBg from '~/components/HeroBg.astro';
import Anim from '~/components/Anim.astro';
import { getCollection } from 'astro:content';
import { listAnimMetas } from '~/lib/anim/registry';
import { PHASES as DSA_PHASES } from '~/lib/dsa-phases';

const notesAll = await getCollection('notes', (n) => !n.data.draft);
const dsaAll = await getCollection('dsa', (n) => !n.data.draft);

// Group systems notes by phase for the phase grid.
interface PhaseBlock {
  slug: string;
  number: string;
  label: string;
  blurb: string;
  count: number;
}
const PHASE_LABELS: Record<string, { label: string; blurb: string }> = {
  '01-foundations': {
    label: 'Foundations',
    blurb: 'Networking, HTTP, DNS, load balancing, REST/gRPC/GraphQL, OS concurrency, storage. The vocabulary every system design uses.',
  },
  '02-databases': {
    label: 'Databases',
    blurb: 'MySQL/Postgres internals, transactions and isolation, replication & sharding, Mongo, Cassandra/Scylla, Elasticsearch.',
  },
  '03-caching-redis': {
    label: 'Caching',
    blurb: 'Cache patterns, Redis internals, stampede & TTL strategy, CDNs.',
  },
  '04-messaging-kafka': {
    label: 'Messaging',
    blurb: 'Kafka deep dive, delivery semantics, CDC, comparison with Pulsar / RabbitMQ / SQS.',
  },
  '05-distributed-systems': {
    label: 'Distributed Systems',
    blurb: 'CAP/PACELC, Raft & Paxos, distributed transactions, rate limiting, circuit breakers, service discovery, time & clocks.',
  },
  '06-hld-patterns': {
    label: 'HLD Patterns',
    blurb: 'Microservices vs monolith, sync/async/event-driven, sharding, multi-region, schema evolution, API gateway / BFF.',
  },
  '07-hld-problems': {
    label: 'HLD Problems',
    blurb: 'Fifteen marquee designs — URL shortener, news feed, chat, notifications, distributed cache, payments, flash sale, video, ride-sharing.',
  },
  '08-data-engineering': {
    label: 'Data Engineering',
    blurb: 'Batch vs streaming, Spark, Trino/Presto, file formats, lakehouse, Airflow, dimensional modeling, data quality, PII.',
  },
  '09-production-craft': {
    label: 'Production Craft',
    blurb: 'Observability, RED/USE, SLOs, alerting, AuthN/Z, mTLS, secrets, OWASP, cloud, k8s, Terraform, CI/CD, testing, flags, DDD.',
  },
  '10-modern-additions': {
    label: 'Modern Additions',
    blurb: 'Real-time push (WS / SSE / long-poll), probabilistic data structures (Bloom / HLL / Count-Min), stream processing (Flink, Kafka Streams).',
  },
};

const phaseCounts = new Map<string, number>();
for (const n of notesAll) {
  phaseCounts.set(n.data.phase, (phaseCounts.get(n.data.phase) ?? 0) + 1);
}
const phases: PhaseBlock[] = Object.entries(PHASE_LABELS).map(([slug, { label, blurb }]) => ({
  slug,
  number: slug.slice(0, 2),
  label,
  blurb,
  count: phaseCounts.get(slug) ?? 0,
}));

// All anims — used by the featured preview at the bottom of the page.
const allAnims = listAnimMetas();
// Pick a random anim per server render. The client can rotate via "Next".
const featured = allAnims[Math.floor(Math.random() * allAnims.length)]!;
const animPool = allAnims.map((a) => ({ id: a.id, title: a.title, caption: a.caption }));

// DSA phase summaries for the pillar-toggle journey card.
const dsaPhaseCounts = new Map<string, number>();
for (const n of dsaAll) {
  dsaPhaseCounts.set(n.data.phase, (dsaPhaseCounts.get(n.data.phase) ?? 0) + 1);
}
const dsaPhases = DSA_PHASES.map((p) => ({
  slug: p.slug,
  number: p.num,
  label: p.title,
  blurb: p.blurb,
  count: dsaPhaseCounts.get(p.slug) ?? 0,
}));

const totalNotes = notesAll.length + dsaAll.length;
const totalAnims = allAnims.length;
const totalPhases = phases.filter((p) => p.count > 0).length;
const totalDsaPhases = dsaPhases.filter((p) => p.count > 0).length;
---
<BaseLayout title="StackTrace — interactive system design & DSA">
  <section class="lp-hero">
    <HeroBg />
    <div class="lp-hero__inner">
      <div class="lp-hero__eyebrow">
        <span>Visualize · Step through · Internalize</span>
      </div>
      <h1 class="lp-hero__title">
        From <em>reading about algorithms</em> to <em>watching them run.</em>
      </h1>
      <p class="lp-hero__sub">
        Every concept here ships with an interactive, step-through visualization.
        {totalAnims} animations spanning DSA and system design, paired with {totalNotes}
        interview-grade notes. Press play on Dijkstra. Watch a Raft leader crash.
        Evict from an LRU cache by hand. The mental model arrives in minutes,
        not weeks — and walks into the interview with you.
      </p>
      <div class="lp-hero__cta">
        <a class="anim__btn anim__btn--primary" href="/roadmap/">Open the roadmap →</a>
        <a class="anim__btn" href="/animations/">Try animations</a>
      </div>
      <div class="lp-hero__meta">
        <span><strong>{totalNotes}</strong> topics</span>
        <span><strong>{totalPhases}</strong> phases</span>
        <span><strong>{totalAnims}</strong> animations</span>
        <span><strong>2</strong> pillars</span>
      </div>
    </div>
  </section>

  <div class="lp-section-head">
    <div>
      <div class="lp-eyebrow">The journey</div>
      <h2>Two pillars, pick where to start</h2>
    </div>
    <div class="lp-section-head__hint">Switch tracks · click a phase to dive in</div>
  </div>

  <section class="journey" data-pillar="systems">
    <div class="journey__tabs" role="tablist" aria-label="Journey track">
      <button
        type="button"
        class="journey__tab"
        role="tab"
        aria-selected="true"
        data-target="systems"
      >
        <span class="journey__tab-name">System Design</span>
        <span class="journey__tab-count">{notesAll.length} topics · {totalPhases} phases</span>
      </button>
      <button
        type="button"
        class="journey__tab"
        role="tab"
        aria-selected="false"
        data-target="dsa"
      >
        <span class="journey__tab-name">DSA</span>
        <span class="journey__tab-count">{dsaAll.length} topics · {totalDsaPhases} patterns</span>
      </button>
    </div>

    <div class="journey__panel journey__panel--systems" role="tabpanel" aria-label="System design phases">
      <div class="phase-grid">
        {phases.map((p, idx) => (
          <a class={`phase-card phase-card--${(idx % 7) + 1}`} href={`/notes/${p.slug}/`}>
            <div class="phase-card__badge">{p.number}</div>
            <h3>{p.label}</h3>
            <p>{p.blurb}</p>
            <span class="phase-card__count">{p.count} topic{p.count === 1 ? '' : 's'}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="journey__panel journey__panel--dsa" role="tabpanel" aria-label="DSA patterns">
      <div class="phase-grid">
        {dsaPhases.map((p, idx) => (
          <a class={`phase-card phase-card--${(idx % 7) + 1}`} href={`/dsa/${p.slug}/`}>
            <div class="phase-card__badge">{p.number}</div>
            <h3>{p.label}</h3>
            <p>{p.blurb}</p>
            <span class="phase-card__count">{p.count} topic{p.count === 1 ? '' : 's'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="lp-section-head">
    <div>
      <div class="lp-eyebrow">Every topic, same shape</div>
      <h2>What you'll find inside</h2>
    </div>
  </div>

  <div class="feat-pills">
    <div class="feat-pill"><span>①</span> Definition</div>
    <div class="feat-pill"><span>②</span> Why it matters</div>
    <div class="feat-pill"><span>③</span> Core concepts</div>
    <div class="feat-pill"><span>④</span> Live animation</div>
    <div class="feat-pill"><span>⑤</span> Real-world examples</div>
    <div class="feat-pill"><span>⑥</span> Common pitfalls</div>
    <div class="feat-pill"><span>⑦</span> Trade-offs</div>
    <div class="feat-pill"><span>⑧</span> When not to use it</div>
  </div>

  <div class="lp-section-head">
    <div>
      <div class="lp-eyebrow">Try one now</div>
      <h2>{totalAnims} interactive animations</h2>
    </div>
    <div class="lp-section-head__hint">Live preview — hit Next for another, or browse all</div>
  </div>

  <section
    class="lp-featured"
    data-current-id={featured.id}
    data-pool={JSON.stringify(animPool)}
    aria-label="Featured animation"
  >
    <div class="lp-featured__head">
      <span class="lp-featured__eyebrow">Featured · live preview</span>
      <h3 class="lp-featured__title" id="lp-featured-title">{featured.title}</h3>
      <p class="lp-featured__caption" id="lp-featured-caption">{featured.caption}</p>
    </div>

    <div class="lp-featured__stage" id="lp-featured-stage">
      <Anim id={featured.id} />
    </div>

    <div class="lp-featured__actions">
      <button type="button" class="anim__btn anim__btn--primary" id="lp-featured-next">
        <span>Next animation</span>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </button>
      <a class="anim__btn" id="lp-featured-open" href={`/animations/${featured.id}/`}>
        Open standalone
      </a>
      <a class="anim__btn" href="/animations/">
        Explore all {totalAnims} →
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  type PoolEntry = { id: string; title: string; caption: string };

  const featured = document.querySelector<HTMLElement>('.lp-featured');
  if (featured) {
    const stage = featured.querySelector<HTMLElement>('#lp-featured-stage');
    const titleEl = featured.querySelector<HTMLElement>('#lp-featured-title');
    const captionEl = featured.querySelector<HTMLElement>('#lp-featured-caption');
    const openLink = featured.querySelector<HTMLAnchorElement>('#lp-featured-open');
    const nextBtn = featured.querySelector<HTMLButtonElement>('#lp-featured-next');

    let pool: PoolEntry[] = [];
    try { pool = JSON.parse(featured.dataset.pool ?? '[]'); } catch { pool = []; }
    let currentId = featured.dataset.currentId ?? pool[0]?.id ?? '';

    function pickNext(): PoolEntry | null {
      if (pool.length === 0) return null;
      if (pool.length === 1) return pool[0]!;
      let pick = pool[Math.floor(Math.random() * pool.length)]!;
      let guard = 0;
      while (pick.id === currentId && guard < 8) {
        pick = pool[Math.floor(Math.random() * pool.length)]!;
        guard++;
      }
      return pick;
    }

    function swapTo(next: PoolEntry): void {
      currentId = next.id;
      if (titleEl) titleEl.textContent = next.title;
      if (captionEl) captionEl.textContent = next.caption;
      if (openLink) openLink.href = `/animations/${next.id}/`;
      if (stage) {
        stage.innerHTML = `<div class="anim-host" data-anim="${next.id}"></div>`;
        import('~/lib/anim/mount').then((m) => { m.mountAll(stage); }).catch(() => {});
      }
    }

    nextBtn?.addEventListener('click', () => {
      const next = pickNext();
      if (next) swapTo(next);
    });
  }

  // Journey pillar toggle — Systems ↔ DSA. CSS swaps the panels.
  const journey = document.querySelector<HTMLElement>('.journey');
  if (journey) {
    const tabs = journey.querySelectorAll<HTMLButtonElement>('.journey__tab');
    for (const tab of tabs) {
      tab.addEventListener('click', () => {
        const target = tab.dataset.target;
        if (!target) return;
        journey.dataset.pillar = target;
        for (const t of tabs) {
          t.setAttribute('aria-selected', String(t === tab));
        }
      });
    }
  }
</script>

<style>
  /* ===== Hero ===== */
  .lp-hero {
    position: relative;
    margin: -2rem -1.5rem 3rem;
    padding: 2.25rem 2rem 3rem;
    border-radius: 0 0 28px 28px;
    overflow: hidden;
    isolation: isolate;
    text-align: center;
  }
  .lp-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(ellipse 70% 50% at 20% 20%, var(--aurora-1), transparent),
      radial-gradient(ellipse 60% 50% at 80% 25%, var(--aurora-2), transparent),
      radial-gradient(ellipse 80% 60% at 50% 100%, var(--aurora-3), transparent);
  }
  .lp-hero__inner { position: relative; max-width: 920px; margin: 0 auto; }

  .lp-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.9rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-radius: 999px;
    margin-bottom: 1.4rem;
  }
  .lp-hero__eyebrow::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: lp-pulse 2s ease-in-out infinite;
  }
  @keyframes lp-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.45; transform: scale(0.85); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lp-hero__eyebrow::before { animation: none; }
  }

  .lp-hero__title {
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 auto 1.4rem;
    max-width: 920px;
  }
  .lp-hero__title em {
    font-style: normal;
    background: var(--grad-1);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lp-hero__sub {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--fg-muted);
    max-width: 640px;
    margin: 0 auto 2rem;
  }
  .lp-hero__cta {
    display: inline-flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.2rem;
  }
  .lp-hero__meta {
    display: inline-flex;
    align-items: center;
    gap: 1.4rem;
    padding: 0.55rem 1.3rem;
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    border: 1px solid var(--card-border);
    border-radius: 999px;
    font-size: 0.78rem;
    color: var(--fg-muted);
  }
  .lp-hero__meta strong {
    color: var(--primary-light);
    font-weight: 700;
    font-family: var(--font-code);
    margin-right: 0.25rem;
  }
  @media (max-width: 600px) {
    .lp-hero { padding: 3.5rem 1.25rem 2.25rem; }
    .lp-hero__meta { flex-direction: column; gap: 0.35rem; border-radius: 14px; }
  }

  /* ===== Section heads ===== */
  .lp-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 3rem 0 1.2rem;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .lp-section-head h2 {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .lp-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-faint);
    margin-bottom: 0.25rem;
  }
  .lp-section-head__hint {
    font-size: 0.78rem;
    color: var(--fg-muted);
  }

  /* ===== Phase cards ===== */
  .phase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin: 1rem 0 2.5rem;
  }
  .phase-card {
    --grad: var(--grad-1);
    position: relative;
    display: block;
    padding: 1.5rem 1.3rem 1.3rem;
    background: var(--card-bg);
    backdrop-filter: blur(14px);
    border: 1px solid var(--card-border);
    border-radius: 18px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    isolation: isolate;
  }
  .phase-card::after {
    content: "";
    position: absolute;
    top: -40px; right: -40px;
    width: 160px; height: 160px;
    background: var(--grad);
    filter: blur(60px);
    opacity: 0.22;
    z-index: -1;
    transition: opacity 0.25s ease;
  }
  .phase-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-shadow), 0 18px 50px rgba(99, 102, 241, 0.18);
    border-color: var(--primary-light);
    text-decoration: none;
  }
  .phase-card:hover::after { opacity: 0.4; }
  .phase-card--1 { --grad: var(--grad-1); }
  .phase-card--2 { --grad: var(--grad-2); }
  .phase-card--3 { --grad: var(--grad-3); }
  .phase-card--4 { --grad: var(--grad-4); }
  .phase-card--5 { --grad: var(--grad-5); }
  .phase-card--6 { --grad: var(--grad-6); }
  .phase-card--7 { --grad: var(--grad-7); }

  .phase-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: 10px;
    background: var(--grad);
    color: white;
    font-family: var(--font-code);
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 0.85rem;
  }
  .phase-card h3 {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .phase-card p {
    margin: 0 0 0.85rem;
    color: var(--fg-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .phase-card__count {
    display: inline-block;
    font-family: var(--font-code);
    font-size: 0.72rem;
    color: var(--fg-faint);
  }

  /* ===== Journey: full-width animated pillar toggle ===== */
  .journey {
    margin: 0.5rem 0 2.5rem;
  }
  /* Full-width segmented tab bar — same width as the card grid below. */
  .journey__tabs {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--bg-soft);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 6px;
    margin-bottom: 1.6rem;
    width: 100%;
  }
  /* Sliding indicator pill — half-width, animates between cells via translateX */
  .journey__tabs::before {
    content: '';
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 6px;
    width: calc(50% - 6px);
    border-radius: 12px;
    background: linear-gradient(135deg, var(--primary-dark, var(--primary)) 0%, var(--primary) 100%);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--primary) 35%, transparent);
    transition: transform 0.45s cubic-bezier(0.6, -0.05, 0.3, 1.4);
    z-index: 0;
  }
  .journey[data-pillar='dsa'] .journey__tabs::before {
    transform: translateX(100%);
  }
  .journey__tab {
    appearance: none;
    position: relative;
    z-index: 1;
    border: none;
    background: transparent;
    color: var(--fg-muted);
    padding: 0.95rem 1.1rem 0.9rem;
    border-radius: 12px;
    font: inherit;
    cursor: pointer;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    line-height: 1.2;
    transition: color 0.3s ease;
  }
  .journey__tab-name {
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .journey__tab-count {
    font-family: var(--font-code);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: inherit;
    opacity: 0.65;
  }
  .journey__tab[aria-selected='true'] {
    color: white;
  }
  .journey__tab[aria-selected='true'] .journey__tab-count { opacity: 0.9; }
  .journey__tab:hover:not([aria-selected='true']) {
    color: var(--fg);
  }

  /* Panels: only the matching pillar is visible, and we animate the enter. */
  .journey[data-pillar='systems'] .journey__panel--dsa,
  .journey[data-pillar='dsa']     .journey__panel--systems { display: none; }

  .journey__panel {
    animation: journey-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes journey-enter {
    0%   { opacity: 0; transform: translateY(14px) scale(0.985); filter: blur(4px); }
    60%  { opacity: 1; filter: blur(0); }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
  }

  /* Staggered card reveal inside the active panel */
  .journey__panel .phase-card {
    animation: phase-card-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) backwards;
  }
  .journey__panel .phase-card:nth-child(1)  { animation-delay: 0.05s; }
  .journey__panel .phase-card:nth-child(2)  { animation-delay: 0.09s; }
  .journey__panel .phase-card:nth-child(3)  { animation-delay: 0.13s; }
  .journey__panel .phase-card:nth-child(4)  { animation-delay: 0.17s; }
  .journey__panel .phase-card:nth-child(5)  { animation-delay: 0.21s; }
  .journey__panel .phase-card:nth-child(6)  { animation-delay: 0.25s; }
  .journey__panel .phase-card:nth-child(7)  { animation-delay: 0.29s; }
  .journey__panel .phase-card:nth-child(8)  { animation-delay: 0.33s; }
  .journey__panel .phase-card:nth-child(9)  { animation-delay: 0.37s; }
  .journey__panel .phase-card:nth-child(n+10) { animation-delay: 0.4s; }
  @keyframes phase-card-pop {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .journey__tabs::before { transition: none; }
    .journey__panel,
    .journey__panel .phase-card { animation: none; }
  }

  /* ===== Featured live preview ===== */
  .lp-featured {
    position: relative;
    margin: 0 0 3rem;
    padding: 1.5rem 1.5rem 1.65rem;
    background: var(--card-bg);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--card-border));
    border-radius: 18px;
    box-shadow: var(--card-shadow);
    backdrop-filter: blur(10px);
