---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Anim from '~/components/Anim.astro';
import { listAnims } from '~/lib/anim/registry';
const featured = listAnims().slice(0, 2);
---
<BaseLayout title="sysviz — interactive system design & DSA">
  <section class="hero">
    <h1 class="hero__title">Systems and algorithms, <em>shown</em>.</h1>
    <p class="hero__sub">
      Interactive visualizations of consensus, replication, sharding, sorting, graphs, and trees — paired with
      structured notes that go deep on each one.
    </p>
    <div class="hero__cta">
      <a class="anim__btn anim__btn--primary" href="/animations/">Open the gallery</a>
      <a class="anim__btn" href="/notes/">Browse notes</a>
    </div>
  </section>

  <section>
    <h2>Featured</h2>
    {featured.map((a) => <Anim id={a.id} />)}
  </section>
</BaseLayout>

<style>
  .hero { padding: 2rem 0 3rem; text-align: center; }
  .hero__title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    background: var(--grad-1);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 1rem;
  }
  .hero__title em { font-style: italic; }
  .hero__sub {
    max-width: 38rem;
    margin: 0 auto 1.75rem;
    color: var(--fg-muted);
    font-size: 1.1rem;
  }
  .hero__cta { display: inline-flex; gap: 0.6rem; flex-wrap: wrap; justify-content: center; }
</style>
