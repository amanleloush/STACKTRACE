---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroBg from '~/components/HeroBg.astro';
import { getCollection } from 'astro:content';
import { listAnimMetas } from '~/lib/anim/registry';

const notesAll = await getCollection('notes', (n) => !n.data.draft);
const dsaAll = await getCollection('dsa', (n) => !n.data.draft);

// Group systems notes by phase for the phase grid.
interface PhaseBlock {
  slug: string;
  number: string;
  label: string;
  blurb: string;
  count: number;
}
const PHASE_LABELS: Record<string, { label: string; blurb: string }> = {
  '01-foundations': {
    label: 'Foundations',
    blurb: 'Networking, HTTP, DNS, load balancing, REST/gRPC/GraphQL, OS concurrency, storage. The vocabulary every system design uses.',
  },
  '02-databases': {
    label: 'Databases',
    blurb: 'MySQL/Postgres internals, transactions and isolation, replication & sharding, Mongo, Cassandra/Scylla, Elasticsearch.',
  },
  '03-caching-redis': {
    label: 'Caching',
    blurb: 'Cache patterns, Redis internals, stampede & TTL strategy, CDNs.',
  },
  '04-messaging-kafka': {
    label: 'Messaging',
    blurb: 'Kafka deep dive, delivery semantics, CDC, comparison with Pulsar / RabbitMQ / SQS.',
  },
  '05-distributed-systems': {
    label: 'Distributed Systems',
    blurb: 'CAP/PACELC, Raft & Paxos, distributed transactions, rate limiting, circuit breakers, service discovery, time & clocks.',
  },
  '06-hld-patterns': {
    label: 'HLD Patterns',
    blurb: 'Microservices vs monolith, sync/async/event-driven, sharding, multi-region, schema evolution, API gateway / BFF.',
  },
  '07-hld-problems': {
    label: 'HLD Problems',
    blurb: 'Fifteen marquee designs — URL shortener, news feed, chat, notifications, distributed cache, payments, flash sale, video, ride-sharing.',
  },
  '08-data-engineering': {
    label: 'Data Engineering',
    blurb: 'Batch vs streaming, Spark, Trino/Presto, file formats, lakehouse, Airflow, dimensional modeling, data quality, PII.',
  },
  '09-production-craft': {
    label: 'Production Craft',
    blurb: 'Observability, RED/USE, SLOs, alerting, AuthN/Z, mTLS, secrets, OWASP, cloud, k8s, Terraform, CI/CD, testing, flags, DDD.',
  },
  '10-modern-additions': {
    label: 'Modern Additions',
    blurb: 'Real-time push (WS / SSE / long-poll), probabilistic data structures (Bloom / HLL / Count-Min), stream processing (Flink, Kafka Streams).',
  },
};

const phaseCounts = new Map<string, number>();
for (const n of notesAll) {
  phaseCounts.set(n.data.phase, (phaseCounts.get(n.data.phase) ?? 0) + 1);
}
const phases: PhaseBlock[] = Object.entries(PHASE_LABELS).map(([slug, { label, blurb }]) => ({
  slug,
  number: slug.slice(0, 2),
  label,
  blurb,
  count: phaseCounts.get(slug) ?? 0,
}));

// Featured anims for the showcase strip.
const allAnims = listAnimMetas();
const showcaseIds = ['raft', 'consistent-hash', 'kafka', 'cap', 'sharding', 'dijkstra'];
const showcase = showcaseIds
  .map((id) => allAnims.find((a) => a.id === id))
  .filter((m): m is NonNullable<typeof m> => m !== undefined);

const totalNotes = notesAll.length + dsaAll.length;
const totalAnims = allAnims.length;
const totalPhases = phases.filter((p) => p.count > 0).length;
---
<BaseLayout title="sysviz — interactive system design & DSA">
  <section class="lp-hero">
    <HeroBg />
    <div class="lp-hero__inner">
      <div class="lp-hero__eyebrow">
        <span>Mid · Senior · Staff · Beyond</span>
      </div>
      <h1 class="lp-hero__title">
        From <em>writes code</em> to <em>designs systems people trust.</em>
      </h1>
      <p class="lp-hero__sub">
        {totalNotes} interview-ready notes across {totalPhases} phases. One topic per page —
        read it and you're interview-ready on that topic. Where pictures beat words, you'll find a
        live animation right next to the text.
      </p>
      <div class="lp-hero__cta">
        <a class="anim__btn anim__btn--primary" href="/roadmap/">Open the roadmap →</a>
        <a class="anim__btn" href="/learn/notes/networking-tcp-udp-tls/">Start at foundations</a>
        <a class="anim__btn" href="/animations/">Try an animation</a>
      </div>
      <div class="lp-hero__meta">
        <span><strong>{totalNotes}</strong> topics</span>
        <span><strong>{totalPhases}</strong> phases</span>
        <span><strong>{totalAnims}</strong> animations</span>
        <span><strong>2</strong> pillars</span>
      </div>
    </div>
  </section>

  <div class="lp-section-head">
    <div>
      <div class="lp-eyebrow">The journey</div>
      <h2>Ten phases of system design</h2>
    </div>
    <div class="lp-section-head__hint">Click any card to open its first note</div>
  </div>

  <div class="phase-grid">
    {phases.map((p, idx) => (
      <a class={`phase-card phase-card--${(idx % 7) + 1}`} href={`/notes/#${p.slug}`}>
        <div class="phase-card__badge">{p.number}</div>
        <h3>{p.label}</h3>
        <p>{p.blurb}</p>
        <span class="phase-card__count">{p.count} topic{p.count === 1 ? '' : 's'}</span>
      </a>
    ))}
  </div>

  <div class="lp-section-head">
    <div>
      <div class="lp-eyebrow">DSA pillar</div>
      <h2>Algorithms, paired with animations</h2>
    </div>
    <div class="lp-section-head__hint">{dsaAll.length} seed notes today, more shipping every week</div>
  </div>

  <div class="lp-dsa-cta">
    <p>
      Same shape as the systems track: one explainer per topic, with an interactive demo embedded
      inline. Browse the DSA index or jump straight to one of the algorithms below.
    </p>
    <a class="anim__btn" href="/dsa/">DSA index →</a>
  </div>

  <div class="lp-section-head">
    <div>
      <div class="lp-eyebrow">Every topic, same shape</div>
      <h2>What you'll find inside</h2>
    </div>
  </div>

  <div class="feat-pills">
    <div class="feat-pill"><span>①</span> Definition</div>
    <div class="feat-pill"><span>②</span> Why it matters</div>
    <div class="feat-pill"><span>③</span> Core concepts</div>
    <div class="feat-pill"><span>④</span> Live animation</div>
    <div class="feat-pill"><span>⑤</span> Real-world examples</div>
    <div class="feat-pill"><span>⑥</span> Common pitfalls</div>
    <div class="feat-pill"><span>⑦</span> Trade-offs</div>
    <div class="feat-pill"><span>⑧</span> When not to use it</div>
  </div>

  <div class="lp-section-head">
    <div>
      <div class="lp-eyebrow">Try one now</div>
      <h2>{totalAnims} interactive animations</h2>
    </div>
    <div class="lp-section-head__hint">Built-in, not screenshots — click, poke, break them</div>
  </div>

  <div class="anim-showcase">
    {showcase.map((a) => (
      <a class="anim-tile" href={`/animations/${a.id}/`}>
        <div class="anim-tile__title">{a.title.split(' — ')[0]}</div>
        <div class="anim-tile__caption">{a.caption}</div>
        <div class="anim-tile__open">Open the demo →</div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .lp-hero {
    position: relative;
    margin: -2rem -1.5rem 3rem;
    padding: 5rem 2rem 3rem;
    border-radius: 0 0 28px 28px;
    overflow: hidden;
    isolation: isolate;
    text-align: center;
  }
  .lp-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(ellipse 70% 50% at 20% 20%, var(--aurora-1), transparent),
      radial-gradient(ellipse 60% 50% at 80% 25%, var(--aurora-2), transparent),
      radial-gradient(ellipse 80% 60% at 50% 100%, var(--aurora-3), transparent);
  }
  .lp-hero__inner { position: relative; max-width: 920px; margin: 0 auto; }

  .lp-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.9rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-radius: 999px;
    margin-bottom: 1.4rem;
  }
  .lp-hero__eyebrow::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: lp-pulse 2s ease-in-out infinite;
  }
  @keyframes lp-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.45; transform: scale(0.85); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lp-hero__eyebrow::before { animation: none; }
  }

  .lp-hero__title {
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 auto 1.4rem;
    max-width: 920px;
  }
  .lp-hero__title em {
    font-style: normal;
    background: var(--grad-1);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lp-hero__sub {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--fg-muted);
    max-width: 640px;
    margin: 0 auto 2rem;
  }
  .lp-hero__cta {
    display: inline-flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.2rem;
  }
  .lp-hero__meta {
    display: inline-flex;
    align-items: center;
    gap: 1.4rem;
    padding: 0.55rem 1.3rem;
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    border: 1px solid var(--card-border);
    border-radius: 999px;
    font-size: 0.78rem;
    color: var(--fg-muted);
  }
  .lp-hero__meta strong {
    color: var(--primary-light);
    font-weight: 700;
    font-family: var(--font-code);
    margin-right: 0.25rem;
  }
  @media (max-width: 600px) {
    .lp-hero { padding: 3.5rem 1.25rem 2.25rem; }
    .lp-hero__meta { flex-direction: column; gap: 0.35rem; border-radius: 14px; }
  }

  /* ===== Section heads ===== */
  .lp-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 3rem 0 1.2rem;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .lp-section-head h2 {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .lp-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-faint);
    margin-bottom: 0.25rem;
  }
  .lp-section-head__hint {
    font-size: 0.78rem;
    color: var(--fg-muted);
  }

  /* ===== Phase cards ===== */
  .phase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin: 1rem 0 2.5rem;
  }
  .phase-card {
    --grad: var(--grad-1);
    position: relative;
    display: block;
    padding: 1.5rem 1.3rem 1.3rem;
    background: var(--card-bg);
    backdrop-filter: blur(14px);
    border: 1px solid var(--card-border);
    border-radius: 18px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    isolation: isolate;
  }
  .phase-card::after {
    content: "";
    position: absolute;
    top: -40px; right: -40px;
    width: 160px; height: 160px;
    background: var(--grad);
    filter: blur(60px);
    opacity: 0.22;
    z-index: -1;
    transition: opacity 0.25s ease;
  }
  .phase-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-shadow), 0 18px 50px rgba(99, 102, 241, 0.18);
    border-color: var(--primary-light);
    text-decoration: none;
  }
  .phase-card:hover::after { opacity: 0.4; }
  .phase-card--1 { --grad: var(--grad-1); }
  .phase-card--2 { --grad: var(--grad-2); }
  .phase-card--3 { --grad: var(--grad-3); }
  .phase-card--4 { --grad: var(--grad-4); }
  .phase-card--5 { --grad: var(--grad-5); }
  .phase-card--6 { --grad: var(--grad-6); }
  .phase-card--7 { --grad: var(--grad-7); }

  .phase-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: 10px;
    background: var(--grad);
    color: white;
    font-family: var(--font-code);
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 0.85rem;
  }
  .phase-card h3 {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .phase-card p {
    margin: 0 0 0.85rem;
    color: var(--fg-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .phase-card__count {
    display: inline-block;
    font-family: var(--font-code);
    font-size: 0.72rem;
    color: var(--fg-faint);
  }

  /* ===== DSA CTA strip ===== */
  .lp-dsa-cta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding: 1.25rem 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    margin: 1rem 0 2.5rem;
  }
  .lp-dsa-cta p {
    margin: 0;
    flex: 1 1 320px;
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  /* ===== Feature pills ===== */
  .feat-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1rem 0 2.5rem;
  }
  .feat-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.85rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 999px;
    font-size: 0.82rem;
    color: var(--fg);
  }
  .feat-pill span {
    color: var(--primary-light);
    font-family: var(--font-code);
    font-weight: 600;
  }

  /* ===== Animation showcase ===== */
  .anim-showcase {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin: 1rem 0 4rem;
  }
  .anim-tile {
    display: block;
    padding: 1.1rem 1.1rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .anim-tile:hover {
    transform: translateY(-2px);
    border-color: var(--primary-light);
    text-decoration: none;
  }
  .anim-tile__title {
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .anim-tile__caption {
    color: var(--fg-muted);
    font-size: 0.85rem;
    line-height: 1.45;
    margin-bottom: 0.85rem;
  }
  .anim-tile__open {
    font-size: 0.8rem;
    color: var(--primary-light);
    font-weight: 600;
  }
</style>
