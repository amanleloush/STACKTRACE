---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Roadmap from '~/components/Roadmap.astro';
---
<BaseLayout title="sysviz — interactive system design & DSA">
  <section class="hero">
    <h1 class="hero__title">Systems and algorithms, <em>shown</em>.</h1>
    <p class="hero__sub">
      Interactive visualizations paired with structured notes. Pick a track,
      pick a topic, watch the algorithm run in your browser.
    </p>
  </section>

  <Roadmap initial="systems" />
</BaseLayout>

<style>
  .hero { padding: 2rem 0 1.5rem; text-align: center; }
  .hero__title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    background: var(--grad-1);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 1rem;
  }
  .hero__title em { font-style: italic; }
  .hero__sub {
    max-width: 38rem;
    margin: 0 auto 1.25rem;
    color: var(--fg-muted);
    font-size: 1.05rem;
  }
</style>
