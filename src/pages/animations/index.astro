---
import BaseLayout from '~/layouts/BaseLayout.astro';
import GalleryGrid from '~/components/GalleryGrid.astro';
---
<BaseLayout
  title="Animations — sysviz"
  description="Filterable gallery of interactive system-design and DSA animations."
>
  <header style="margin-bottom: 1rem;">
    <h1>Animations</h1>
    <p style="color: var(--fg-muted); max-width: 44rem;">
      Every animation runs in your browser. Click a card to open the standalone, deep-linkable view,
      or embed any of them in a note with <code>&lt;Anim id="…"/&gt;</code>.
    </p>
  </header>
  <GalleryGrid />
</BaseLayout>
