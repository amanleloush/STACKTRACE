---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Anim from '~/components/Anim.astro';
import Paywall from '~/components/Paywall.astro';
import { getMeta } from '~/lib/anim/registry';
import { getDb } from '~/lib/db';
import { canAccess } from '~/lib/billing/entitlement';

// SSR (not prerendered) so we can run the entitlement check against the
// current user's session — same gating pattern as /learn/dsa/[slug].astro.
// Standalone anim deep-links honor admin overrides + per-anim premium just
// like the embedded <Anim> in note bodies.
export const prerender = false;

const { id } = Astro.params;
if (!id) return new Response('Not found', { status: 404 });
const anim = getMeta(id);
if (!anim) return new Response('Not found', { status: 404 });

const env = Astro.locals.runtime?.env;
const db = await getDb({ env });
const access = await canAccess(
  db,
  {
    kind: 'anim',
    id: anim.id,
    defaultPremium: anim.premium ?? false,
  },
  Astro.locals.user,
);

Astro.response.headers.set('Vary', 'Cookie');
if (Astro.locals.user || import.meta.env.DEV) {
  Astro.response.headers.set('Cache-Control', 'private, no-store');
} else {
  Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=300');
}
---
<BaseLayout title={`${anim.title} — StackTrace`} description={anim.caption}>
  <nav style="margin-bottom: 1rem; font-size: 0.85rem; color: var(--fg-muted);">
    <a href="/animations/">← Animations</a>
  </nav>
  <header style="margin-bottom: 1rem;">
    <h1 style="margin-bottom: 0.5rem;">{anim.title}</h1>
    <p style="color: var(--fg-muted); margin: 0 0 0.75rem;">{anim.caption}</p>
    <div>
      {anim.tags.map((t) => <span class="tag" style="margin-right: 0.3rem;">{t}</span>)}
    </div>
  </header>

  {access.allowed
    ? <Anim id={anim.id} />
    : <Paywall reason="anim" next={Astro.url.pathname} />}
</BaseLayout>
