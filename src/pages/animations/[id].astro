---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Anim from '~/components/Anim.astro';
import { listAnimMetas, getMeta } from '~/lib/anim/registry';

export function getStaticPaths() {
  return listAnimMetas().map((a) => ({ params: { id: a.id } }));
}

const { id } = Astro.params;
const anim = getMeta(id!);
if (!anim) throw new Error(`Unknown animation: ${id}`);
---
<BaseLayout title={`${anim.title} — sysviz`} description={anim.caption}>
  <nav style="margin-bottom: 1rem; font-size: 0.85rem; color: var(--fg-muted);">
    <a href="/animations/">← Animations</a>
  </nav>
  <header style="margin-bottom: 1rem;">
    <h1 style="margin-bottom: 0.5rem;">{anim.title}</h1>
    <p style="color: var(--fg-muted); margin: 0 0 0.75rem;">{anim.caption}</p>
    <div>
      {anim.tags.map((t) => <span class="tag" style="margin-right: 0.3rem;">{t}</span>)}
    </div>
  </header>

  <Anim id={anim.id} />
</BaseLayout>
