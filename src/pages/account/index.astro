---
import BaseLayout from '~/layouts/BaseLayout.astro';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login/?next=/account/');
}
---
<BaseLayout title="Account — sysviz">
  <section class="account">
    <h1>Account</h1>
    <div class="account__card">
      <div class="account__row"><span>Email</span><strong>{user.email}</strong></div>
      <div class="account__row"><span>Name</span><strong>{user.name ?? '—'}</strong></div>
      <div class="account__row"><span>Role</span><strong>{user.role}</strong></div>
    </div>

    <p class="account__hint">
      Subscriptions, progress tracking, and bookmarks land in later phases.
      For now, sign-in is enough to flip into admin mode (if your email is on the ADMIN_EMAILS list).
    </p>

    <form action="/api/auth/logout" method="post">
      <button type="submit" class="anim__btn">Sign out</button>
    </form>
  </section>
</BaseLayout>

<style>
  .account { max-width: 32rem; margin: 3rem auto; }
  .account__card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }
  .account__row {
    display: flex;
    justify-content: space-between;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--card-border);
    font-size: 0.92rem;
  }
  .account__row:last-child { border-bottom: none; }
  .account__row span { color: var(--fg-muted); }
  .account__hint { color: var(--fg-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1.5rem; }
</style>
