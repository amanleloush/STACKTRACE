---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Roadmap from '~/components/Roadmap.astro';
---
<BaseLayout
  title="Roadmap — StackTrace"
  description="Two pillars — system design and DSA. Pick a topic to jump into the paired note and animation."
>
  <header class="roadmap-page__head">
    <h1>Roadmap</h1>
    <p class="roadmap-page__sub">
      The whole library at a glance. Toggle between the two pillars; every chip is one note
      with a paired animation.
    </p>
  </header>
  <Roadmap initial="systems" />
</BaseLayout>

<style>
  .roadmap-page__head { margin-bottom: 1.5rem; }
  .roadmap-page__sub {
    color: var(--fg-muted);
    margin: 0.5rem 0 0;
    max-width: 42rem;
  }
</style>
