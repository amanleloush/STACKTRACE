---
import BaseLayout from '~/layouts/BaseLayout.astro';

export const prerender = false;

// middleware.ts has already 404'd anyone who isn't admin by the time we run.
const user = Astro.locals.user!;
---
<BaseLayout title="Admin — sysviz">
  <section class="admin">
    <h1>Admin</h1>
    <p class="admin__sub">
      Signed in as <strong>{user.email}</strong> (<code>{user.role}</code>).
      Every change here writes to the <code>entitlement_overrides</code> /
      <code>feature_flags</code> tables — picked up on the next request, no
      redeploy.
    </p>

    <nav class="admin__cards">
      <a class="admin__card" href="/admin/content/">
        <h2>Content gating</h2>
        <p>Per-entity premium toggle for notes, animations, and Premium blocks.</p>
      </a>
      <a class="admin__card admin__card--soon">
        <h2>Users <span class="admin__soon">soon</span></h2>
        <p>List + manual tier overrides. Lands when Razorpay does (Phase 4).</p>
      </a>
      <a class="admin__card admin__card--soon">
        <h2>Feature flags <span class="admin__soon">soon</span></h2>
        <p>Toggle the AI chatbot, PDF export, etc. Lands Phase 7.</p>
      </a>
    </nav>
  </section>
</BaseLayout>

<style>
  .admin { max-width: 48rem; margin: 2rem auto; }
  .admin__sub { color: var(--fg-muted); line-height: 1.6; margin-bottom: 2rem; }
  .admin__sub code {
    background: var(--code-bg);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
  }
  .admin__cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .admin__card {
    display: block;
    padding: 1.2rem 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, border-color 0.15s;
  }
  .admin__card:hover:not(.admin__card--soon) {
    transform: translateY(-2px);
    border-color: var(--primary-light);
    text-decoration: none;
  }
  .admin__card--soon { opacity: 0.6; cursor: not-allowed; }
  .admin__card h2 { margin: 0 0 0.4rem; font-size: 1rem; }
  .admin__card p { margin: 0; color: var(--fg-muted); font-size: 0.85rem; line-height: 1.5; }
  .admin__soon {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--card-border);
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    margin-left: 0.3rem;
    color: var(--fg-muted);
  }
</style>
