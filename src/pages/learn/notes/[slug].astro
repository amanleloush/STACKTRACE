---
import { getEntry, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import NoteLayout from '~/components/NoteLayout.astro';
import Anim from '~/components/Anim.astro';
import Premium from '~/components/Premium.astro';
import Paywall from '~/components/Paywall.astro';
import { getDb } from '~/lib/db';
import { canAccess } from '~/lib/billing/entitlement';

export const prerender = false;

const slug = Astro.params.slug;
if (!slug) return new Response('Not found', { status: 404 });

const entry = await getEntry('notes', slug);
if (!entry || entry.data.draft) return new Response('Not found', { status: 404 });

const env = Astro.locals.runtime?.env;
const db = await getDb({ env });

// Stash the entry so <Premium> blocks can derive the block entity_id.
Astro.locals.entry = entry;

const access = await canAccess(
  db,
  {
    kind: 'note',
    id: entry.id,
    defaultPremium: entry.data.premium,
    defaultPreviewParagraphs: entry.data.previewParagraphs,
  },
  Astro.locals.user,
);

// Edge-cache strategy (plan §14e). Authenticated responses must bypass
// any cache so admin gate-flips appear immediately. Anonymous responses
// can be CDN-cached in prod against the cookie — but in dev we force
// no-store so the browser doesn't serve a stale anon paywall to a user
// who just signed in.
Astro.response.headers.set('Vary', 'Cookie');
if (Astro.locals.user || import.meta.env.DEV) {
  Astro.response.headers.set('Cache-Control', 'private, no-store');
} else {
  Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=300');
}

const { Content } = access.allowed
  ? await render(entry)
  : { Content: null };
---
<BaseLayout
  title={`${entry.data.title} — StackTrace`}
  description={entry.data.summary ?? entry.data.title}
>
  <NoteLayout entry={entry} collectionLabel="System Design" effectivePremium={!access.allowed || entry.data.premium}>
    {access.allowed && Content
      ? <Content components={{ Anim, Premium }} />
      : <Paywall reason="note" />}
  </NoteLayout>
</BaseLayout>
