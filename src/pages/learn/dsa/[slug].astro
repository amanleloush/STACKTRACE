---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import NoteLayout from '~/components/NoteLayout.astro';
import Anim from '~/components/Anim.astro';
import Premium from '~/components/Premium.astro';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('dsa', (n) => !n.data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'dsa'>;
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout
  title={`${entry.data.title} — sysviz`}
  description={entry.data.summary ?? entry.data.title}
>
  <NoteLayout entry={entry} collectionLabel="DSA">
    <Content components={{ Anim, Premium }} />
  </NoteLayout>
</BaseLayout>
