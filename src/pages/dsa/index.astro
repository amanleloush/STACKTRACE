---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';

const all = await getCollection('dsa', (n) => !n.data.draft);

interface PhaseGroup {
  slug: string;
  label: string;
  notes: typeof all;
}

const groupMap = new Map<string, typeof all>();
for (const n of all) {
  const arr = groupMap.get(n.data.phase) ?? [];
  arr.push(n);
  groupMap.set(n.data.phase, arr);
}
for (const arr of groupMap.values()) {
  arr.sort((a, b) => a.data.order - b.data.order);
}

function phaseLabel(slug: string): string {
  return slug
    .replace(/^[0-9]+-/, '')
    .replace(/-/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

const phases: PhaseGroup[] = [...groupMap.keys()]
  .sort()
  .map((slug) => ({
    slug,
    label: phaseLabel(slug),
    notes: groupMap.get(slug)!,
  }));

const totalNotes = all.length;
const totalMinutes = all.reduce((s, n) => s + (n.data.estimatedMinutes ?? 0), 0);
---
<BaseLayout
  title="DSA — sysviz"
  description={`${totalNotes} DSA notes, each paired with an animated walkthrough.`}
>
  <header class="notes-head">
    <h1>DSA</h1>
    <p class="notes-sub">
      {totalNotes} notes ·{' '}
      {totalMinutes ? `~${Math.max(1, Math.round(totalMinutes / 60))} h reading · ` : ''}
      pairs every topic with a runnable animation.
    </p>
  </header>

  {phases.length === 0 ? (
    <p style="color: var(--fg-muted)">
      DSA notes coming soon — the pillar is being built out in Phase 2.
    </p>
  ) : (
    <div class="phases">
      {phases.map((phase) => (
        <section class="phase">
          <header class="phase__head">
            <h2 class="phase__title">{phase.label}</h2>
            <span class="phase__count">{phase.notes.length}</span>
          </header>
          <ul class="phase__list">
            {phase.notes.map((n) => (
              <li class="phase__item">
                <a class="phase__link" href={`/learn/dsa/${n.id}/`}>
                  <span class="phase__order">{String(n.data.order).padStart(2, '0')}</span>
                  <span class="phase__title-text">{n.data.title}</span>
                  <span class="phase__meta">
                    {n.data.estimatedMinutes && (
                      <span class="phase__minutes">{n.data.estimatedMinutes}m</span>
                    )}
                    {n.data.premium && <span class="phase__lock">🔒</span>}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  .notes-head { margin-bottom: 2.5rem; }
  .notes-sub { color: var(--fg-muted); margin: 0.5rem 0 0; }
  .phases { display: grid; gap: 2.5rem; }
  .phase__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--card-border);
  }
  .phase__title {
    margin: 0;
    font-size: 1.15rem;
    background: var(--grad-3);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .phase__count {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--fg-muted);
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }
  .phase__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.25rem; }
  .phase__item { margin: 0; }
  .phase__link {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    transition: background 0.12s ease;
  }
  .phase__link:hover {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    text-decoration: none;
  }
  .phase__order { font-family: var(--font-code); font-size: 0.8rem; color: var(--fg-faint); }
  .phase__title-text { font-size: 0.95rem; }
  .phase__meta { display: inline-flex; gap: 0.5rem; align-items: center; }
  .phase__minutes { font-family: var(--font-code); font-size: 0.75rem; color: var(--fg-muted); }
  .phase__lock { font-size: 0.85rem; }
</style>
