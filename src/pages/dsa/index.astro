---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { PHASES } from '~/lib/dsa-phases';

const all = await getCollection('dsa', (n) => !n.data.draft);

const notesByPhase = new Map<string, typeof all>();
for (const n of all) {
  const arr = notesByPhase.get(n.data.phase) ?? [];
  arr.push(n);
  notesByPhase.set(n.data.phase, arr);
}
for (const arr of notesByPhase.values()) {
  arr.sort((a, b) => a.data.order - b.data.order);
}

const totalNotes = all.length;
const totalMinutes = all.reduce((s, n) => s + (n.data.estimatedMinutes ?? 0), 0);

const cheatSheet: Array<{ op: string; cells: string[] }> = [
  { op: 'Lookup',  cells: ['O(n)', 'O(log n)', 'O(1) avg', 'O(log n)', 'O(n)', 'O(L)'] },
  { op: 'Insert',  cells: ['O(1) end / O(n) mid', 'O(n)', 'O(1) avg', 'O(log n)', 'O(log n)', 'O(L)'] },
  { op: 'Delete',  cells: ['O(n)', 'O(n)', 'O(1) avg', 'O(log n)', 'O(log n)', 'O(L)'] },
  { op: 'Min/Max', cells: ['O(n)', 'O(1)', 'O(n)', 'O(log n)', 'O(1)', 'O(L)'] },
  { op: 'Range',   cells: ['O(n)', 'O(log n + k)', 'O(n)', 'O(log n + k)', '—', '—'] },
];
---
<BaseLayout
  title="DSA · Interview Prep — StackTrace"
  description={`${PHASES.length} algorithm patterns, ${totalNotes} note${totalNotes === 1 ? '' : 's'} so far — each paired with a step-through visualization.`}
>
  <header class="dsa-head">
    <h1>DSA — Interview Prep</h1>
    <p class="dsa-lede">
      <strong>Learn algorithms by <em>watching</em> them run.</strong> Every algorithm here ships
      with a step-by-step visualization where you see the state evolve and the corresponding line of
      code light up. Pattern-first, the way working engineers think about problems.
    </p>
    <p class="dsa-sub">
      {PHASES.length} patterns · {totalNotes} note{totalNotes === 1 ? '' : 's'} live
      {totalMinutes ? ` · ~${Math.max(1, Math.round(totalMinutes / 60))} h reading` : ''}
    </p>
  </header>

  <section class="topic-grid">
    {PHASES.map((p) => {
      const count = notesByPhase.get(p.slug)?.length ?? 0;
      return (
        <a class="topic-card" href={`/dsa/${p.slug}/`} data-empty={count === 0}>
          <span class="topic-card__num">{p.num}</span>
          <h3>{p.title}</h3>
          <p>{p.blurb}</p>
          <span class="topic-card__count">
            {count === 0 ? 'Coming soon' : `${count} note${count === 1 ? '' : 's'}`}
          </span>
        </a>
      );
    })}
  </section>

  <section class="how-to">
    <h2>How to use this section</h2>
    <ol>
      <li><strong>Pick a pattern</strong> — start with the ones that come up most: Two Pointers, Sliding Window, Binary Search, BFS, DFS, DP.</li>
      <li><strong>Read the explanation</strong> — every page has the algorithm in plain English, intuition, complexity, and pitfalls.</li>
      <li><strong>Step through the visualization</strong> — every page has an interactive widget with Play / Step / Reset and a code panel that highlights the currently-executing line.</li>
      <li><strong>Practice on LeetCode</strong> — every page ends with curated practice problems ranked easy → hard.</li>
    </ol>
  </section>

  <section class="why-patterns">
    <h2>Why pattern-first</h2>
    <p>
      Interview problems are rarely truly novel — they're variations on a small set of patterns. Once
      you can recognize the pattern in the first 60 seconds ("this is sliding window because we want
      the longest contiguous range satisfying X"), the implementation becomes mechanical. This
      section trains pattern recognition.
    </p>
  </section>

  <section class="cheat">
    <h2>Time / space cheat sheet</h2>
    <div class="cheat__scroll">
      <table>
        <thead>
          <tr>
            <th>Operation</th><th>Array</th><th>Sorted Array</th><th>Hash Map</th>
            <th>BST (balanced)</th><th>Heap</th><th>Trie</th>
          </tr>
        </thead>
        <tbody>
          {cheatSheet.map((row) => (
            <tr>
              <th scope="row">{row.op}</th>
              {row.cells.map((c) => <td>{c}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="cheat__legend">L = key length. k = output size.</p>
  </section>

</BaseLayout>

<style>
  .dsa-head { margin-bottom: 2.5rem; }
  .dsa-lede { font-size: 1.05rem; line-height: 1.55; color: var(--fg); max-width: 70ch; }
  .dsa-sub { color: var(--fg-muted); margin: 0.75rem 0 0; font-size: 0.9rem; }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin: 2rem 0 3rem;
  }
  .topic-card {
    position: relative;
    display: block;
    padding: 1rem 1.1rem 2.4rem;
    border: 1px solid var(--card-border);
    border-radius: 12px;
    background: var(--card-bg);
    color: var(--fg);
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease, background 0.15s ease;
  }
  .topic-card:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, var(--card-bg));
    text-decoration: none;
    transform: translateY(-1px);
  }
  .topic-card[data-empty="true"] { opacity: 0.78; }
  .topic-card__num {
    font-family: var(--font-code);
    font-size: 0.75rem;
    color: var(--fg-faint);
    letter-spacing: 0.06em;
  }
  .topic-card h3 {
    margin: 0.15rem 0 0.4rem;
    font-size: 1.05rem;
    background: var(--grad-3);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .topic-card p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .topic-card__count {
    position: absolute;
    bottom: 0.7rem;
    left: 1.1rem;
    font-family: var(--font-code);
    font-size: 0.7rem;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .how-to, .why-patterns, .cheat, .refs { margin: 2.5rem 0; }
  .how-to ol { line-height: 1.6; padding-left: 1.2rem; }
  .why-patterns p { max-width: 72ch; line-height: 1.6; }

  .cheat__scroll { overflow-x: auto; }
  .cheat table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  .cheat th, .cheat td {
    text-align: left;
    padding: 0.45rem 0.7rem;
    border-bottom: 1px solid var(--card-border);
  }
  .cheat thead th { color: var(--fg-muted); font-weight: 600; }
  .cheat tbody th { color: var(--fg); font-weight: 600; }
  .cheat__legend { color: var(--fg-faint); font-size: 0.8rem; margin-top: 0.5rem; }

  .refs ul { line-height: 1.7; padding-left: 1.2rem; }
</style>
