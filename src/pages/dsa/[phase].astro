---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { PHASES, type DsaPhase } from '~/lib/dsa-phases';

export async function getStaticPaths() {
  return PHASES.map((p) => ({
    params: { phase: p.slug },
    props: { phase: p },
  }));
}

interface Props {
  phase: DsaPhase;
}

const { phase } = Astro.props;

const notes = (await getCollection('dsa', (n) => !n.data.draft && n.data.phase === phase.slug))
  .sort((a, b) => a.data.order - b.data.order);

const totalMinutes = notes.reduce((s, n) => s + (n.data.estimatedMinutes ?? 0), 0);
---
<BaseLayout
  title={`${phase.title} · DSA — sysviz`}
  description={phase.blurb}
>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/dsa/">← Back to DSA</a>
  </nav>

  <header class="phase-head">
    <span class="phase-head__num">{phase.num}</span>
    <h1 class="phase-head__title">{phase.title}</h1>
    <p class="phase-head__blurb">{phase.blurb}</p>
    <p class="phase-head__sub">
      {notes.length} note{notes.length === 1 ? '' : 's'}
      {totalMinutes ? ` · ~${totalMinutes} min total` : ''}
    </p>
  </header>

  {notes.length === 0 ? (
    <p class="phase-empty">Coming soon — articles for this pattern are still being written.</p>
  ) : (
    <ul class="phase-list">
      {notes.map((n) => (
        <li class="phase-item">
          <a class="phase-link" href={`/learn/dsa/${n.id}/`}>
            <span class="phase-order">{String(n.data.order).padStart(2, '0')}</span>
            <span class="phase-title-text">{n.data.title}</span>
            <span class="phase-meta">
              {n.data.estimatedMinutes && (
                <span class="phase-minutes">{n.data.estimatedMinutes}m</span>
              )}
              {n.data.premium && <span class="phase-lock" aria-label="premium">🔒</span>}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .crumbs {
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .crumbs a {
    color: var(--fg-muted);
    text-decoration: none;
  }
  .crumbs a:hover { color: var(--accent); }

  .phase-head { margin-bottom: 2.5rem; }
  .phase-head__num {
    font-family: var(--font-code);
    font-size: 0.85rem;
    color: var(--fg-faint);
    letter-spacing: 0.06em;
  }
  .phase-head__title {
    margin: 0.25rem 0 0.75rem;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    background: var(--grad-3);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .phase-head__blurb {
    margin: 0;
    color: var(--fg);
    max-width: 70ch;
    line-height: 1.5;
  }
  .phase-head__sub {
    margin: 0.75rem 0 0;
    color: var(--fg-muted);
    font-size: 0.9rem;
  }

  .phase-empty {
    color: var(--fg-faint);
    font-style: italic;
    padding: 1.25rem;
    border: 1px dashed var(--card-border);
    border-radius: 10px;
    background: var(--card-bg);
  }

  .phase-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.4rem;
  }
  .phase-item { margin: 0; }
  .phase-link {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.65rem 0.9rem;
    border-radius: 10px;
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  .phase-link:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, var(--card-bg));
    text-decoration: none;
    transform: translateY(-1px);
  }
  .phase-order { font-family: var(--font-code); font-size: 0.8rem; color: var(--fg-faint); }
  .phase-title-text { font-size: 0.98rem; }
  .phase-meta { display: inline-flex; gap: 0.5rem; align-items: center; }
  .phase-minutes { font-family: var(--font-code); font-size: 0.75rem; color: var(--fg-muted); }
  .phase-lock { font-size: 0.85rem; }
</style>
