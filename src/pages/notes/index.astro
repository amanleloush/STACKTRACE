---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { NOTES_PHASES } from '~/lib/notes-phases';

const all = await getCollection('notes', (n) => !n.data.draft);
const notesByPhase = new Map<string, typeof all>();
for (const n of all) {
  const arr = notesByPhase.get(n.data.phase) ?? [];
  arr.push(n);
  notesByPhase.set(n.data.phase, arr);
}

const totalNotes = all.length;
const totalMinutes = all.reduce((s, n) => s + (n.data.estimatedMinutes ?? 0), 0);
const livePhases = NOTES_PHASES.filter((p) => (notesByPhase.get(p.slug)?.length ?? 0) > 0).length;
---
<BaseLayout
  title="System Design — StackTrace"
  description={`${totalNotes} system-design notes across ${livePhases} phases. Pick a phase to dive in.`}
>
  <header class="notes-head">
    <h1>System Design</h1>
    <p class="notes-sub">
      {totalNotes} notes · {livePhases} phases ·{' '}
      {totalMinutes ? `~${Math.max(1, Math.round(totalMinutes / 60))} h reading` : ''}
    </p>
    <p class="notes-hint">
      Pick a phase — each has its own page with the topic list inside.
    </p>
  </header>

  <section class="topic-grid">
    {NOTES_PHASES.map((p) => {
      const count = notesByPhase.get(p.slug)?.length ?? 0;
      return (
        <a class="topic-card" href={`/notes/${p.slug}/`} data-empty={count === 0}>
          <span class="topic-card__num">{p.num}</span>
          <h3>{p.title}</h3>
          <p>{p.blurb}</p>
          <span class="topic-card__count">
            {count === 0 ? 'Coming soon' : `${count} note${count === 1 ? '' : 's'}`}
          </span>
        </a>
      );
    })}
  </section>
</BaseLayout>

<style>
  .notes-head {
    margin-bottom: 2.5rem;
    text-align: center;
  }
  .notes-head h1 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin: 0;
    background: var(--grad-3);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: 800;
  }
  .notes-sub {
    color: var(--fg-muted);
    margin: 0.5rem 0 0;
  }
  .notes-hint {
    color: var(--fg-faint);
    font-size: 0.88rem;
    margin: 0.25rem 0 0;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .topic-card {
    position: relative;
    display: block;
    padding: 1rem 1.1rem 2.4rem;
    border: 1px solid var(--card-border);
    border-radius: 12px;
    background: var(--card-bg);
    color: var(--fg);
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease, background 0.15s ease;
  }
  .topic-card:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, var(--card-bg));
    text-decoration: none;
    transform: translateY(-1px);
  }
  .topic-card[data-empty="true"] { opacity: 0.78; }
  .topic-card__num {
    font-family: var(--font-code);
    font-size: 0.75rem;
    color: var(--fg-faint);
    letter-spacing: 0.06em;
  }
  .topic-card h3 {
    margin: 0.15rem 0 0.4rem;
    font-size: 1.05rem;
    background: var(--grad-3);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .topic-card p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .topic-card__count {
    position: absolute;
    bottom: 0.7rem;
    left: 1.1rem;
    font-family: var(--font-code);
    font-size: 0.7rem;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
