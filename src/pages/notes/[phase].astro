---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { NOTES_PHASES, type NotesPhase } from '~/lib/notes-phases';

export async function getStaticPaths() {
  return NOTES_PHASES.map((p) => ({
    params: { phase: p.slug },
    props: { phase: p },
  }));
}

interface Props {
  phase: NotesPhase;
}

const { phase } = Astro.props;

const notes = (await getCollection('notes', (n) => !n.data.draft && n.data.phase === phase.slug))
  .sort((a, b) => a.data.order - b.data.order);

const totalMinutes = notes.reduce((s, n) => s + (n.data.estimatedMinutes ?? 0), 0);

// Cross-phase navigation — next / previous phase so readers can keep
// moving forward without going back to the index every time.
const phaseIdx = NOTES_PHASES.findIndex((p) => p.slug === phase.slug);
const prevPhase = phaseIdx > 0 ? NOTES_PHASES[phaseIdx - 1] : null;
const nextPhase = phaseIdx < NOTES_PHASES.length - 1 ? NOTES_PHASES[phaseIdx + 1] : null;
---
<BaseLayout
  title={`${phase.title} · System Design — StackTrace`}
  description={phase.blurb}
>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/notes/">← All system-design phases</a>
  </nav>

  <header class="phase-head">
    <span class="phase-head__num">{phase.num}</span>
    <h1 class="phase-head__title">{phase.title}</h1>
    <p class="phase-head__blurb">{phase.blurb}</p>
    <p class="phase-head__sub">
      {notes.length} note{notes.length === 1 ? '' : 's'}
      {totalMinutes ? ` · ~${totalMinutes} min total` : ''}
    </p>
  </header>

  {notes.length === 0 ? (
    <p class="phase-empty">Coming soon — notes for this phase are still being written.</p>
  ) : (
    <ul class="phase-list">
      {notes.map((n) => (
        <li class="phase-item">
          <a class="phase-link" href={`/learn/notes/${n.id}/`}>
            <span class="phase-order">{String(n.data.order).padStart(2, '0')}</span>
            <div class="phase-body">
              <span class="phase-title-text">{n.data.title}</span>
              {n.data.summary && <span class="phase-summary">{n.data.summary}</span>}
            </div>
            <span class="phase-meta">
              {n.data.estimatedMinutes && (
                <span class="phase-minutes">{n.data.estimatedMinutes}m</span>
              )}
              {n.data.premium && <span class="phase-lock" aria-label="premium">🔒</span>}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}

  <nav class="phase-nav" aria-label="Adjacent phases">
    {prevPhase ? (
      <a href={`/notes/${prevPhase.slug}/`} class="phase-nav__link phase-nav__link--prev">
        <span class="phase-nav__dir">← Previous phase</span>
        <span class="phase-nav__title">{prevPhase.num} · {prevPhase.title}</span>
      </a>
    ) : <span></span>}
    {nextPhase && (
      <a href={`/notes/${nextPhase.slug}/`} class="phase-nav__link phase-nav__link--next">
        <span class="phase-nav__dir">Next phase →</span>
        <span class="phase-nav__title">{nextPhase.num} · {nextPhase.title}</span>
      </a>
    )}
  </nav>
</BaseLayout>

<style>
  .crumbs {
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .crumbs a {
    color: var(--fg-muted);
    text-decoration: none;
  }
  .crumbs a:hover { color: var(--accent); }

  .phase-head { margin-bottom: 2.5rem; }
  .phase-head__num {
    font-family: var(--font-code);
    font-size: 0.85rem;
    color: var(--fg-faint);
    letter-spacing: 0.06em;
  }
  .phase-head__title {
    margin: 0.25rem 0 0.75rem;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    background: var(--grad-3);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: 800;
  }
  .phase-head__blurb {
    margin: 0;
    color: var(--fg);
    max-width: 70ch;
    line-height: 1.5;
  }
  .phase-head__sub {
    margin: 0.75rem 0 0;
    color: var(--fg-muted);
    font-size: 0.9rem;
  }

  .phase-empty {
    color: var(--fg-faint);
    font-style: italic;
    padding: 1.25rem;
    border: 1px dashed var(--card-border);
    border-radius: 10px;
    background: var(--card-bg);
  }

  .phase-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .phase-item { margin: 0; }
  .phase-link {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  .phase-link:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, var(--card-bg));
    text-decoration: none;
    transform: translateY(-1px);
  }
  .phase-order { font-family: var(--font-code); font-size: 0.8rem; color: var(--fg-faint); }
  .phase-body { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; }
  .phase-title-text { font-size: 0.98rem; font-weight: 600; }
  .phase-summary {
    font-size: 0.82rem;
    color: var(--fg-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .phase-meta { display: inline-flex; gap: 0.5rem; align-items: center; }
  .phase-minutes {
    font-family: var(--font-code);
    font-size: 0.72rem;
    color: var(--fg-muted);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-weight: 600;
  }
  .phase-lock { font-size: 0.85rem; }

  /* Prev / next phase footer */
  .phase-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--card-border) 60%, transparent);
  }
  .phase-nav__link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.9rem 1.1rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .phase-nav__link:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, var(--card-bg));
    text-decoration: none;
  }
  .phase-nav__link--next { text-align: right; }
  .phase-nav__dir {
    font-family: var(--font-code);
    font-size: 0.7rem;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  .phase-nav__title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--fg);
  }
  @media (max-width: 600px) {
    .phase-link { grid-template-columns: 2rem 1fr; gap: 0.65rem; }
    .phase-meta { grid-column: 1 / -1; margin-top: 0.25rem; }
    .phase-nav { grid-template-columns: 1fr; }
    .phase-nav__link--next { text-align: left; }
  }
</style>
