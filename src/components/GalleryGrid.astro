---
import { listAnims } from '~/lib/anim/registry';
const anims = listAnims();
const allTags = [...new Set(anims.flatMap((a) => a.tags))].sort();
---
<section class="gallery">
  <div class="gallery__filter" role="group" aria-label="Filter animations">
    <input
      type="search"
      id="gallery-search"
      placeholder="Search animations…"
      class="gallery__search"
      aria-label="Search animations by title"
    />
    <div class="gallery__tags">
      <button type="button" class="tag-btn" data-tag="all" aria-pressed="true">all</button>
      {allTags.map((t) => (
        <button type="button" class="tag-btn" data-tag={t} aria-pressed="false">{t}</button>
      ))}
    </div>
  </div>

  <ul class="gallery__grid" id="gallery-grid">
    {anims.map((a) => (
      <li
        class="gallery__card"
        data-title={a.title.toLowerCase()}
        data-tags={a.tags.join(' ')}
        data-pillar={a.pillar}
      >
        <a href={`/animations/${a.id}/`} class="gallery__link">
          <div class="gallery__card-title">{a.title}</div>
          <p class="gallery__card-caption">{a.caption}</p>
          <div class="gallery__card-tags">
            {a.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .gallery { margin-top: 1rem; }
  .gallery__filter {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .gallery__search {
    width: 100%;
    padding: 0.6rem 0.9rem;
    border-radius: 9px;
    border: 1px solid var(--card-border);
    background: var(--bg-soft);
    color: var(--fg);
    font: inherit;
  }
  .gallery__search::placeholder { color: var(--fg-faint); }
  .gallery__tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag-btn {
    appearance: none;
    border: 1px solid var(--card-border);
    background: var(--bg-soft);
    color: var(--fg-muted);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
  }
  .tag-btn[aria-pressed="true"] {
    background: var(--primary);
    color: white;
    border-color: transparent;
  }
  .gallery__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }
  .gallery__card {
    border-radius: 12px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .gallery__card:hover { transform: translateY(-2px); border-color: var(--primary-light); }
  .gallery__link {
    display: block;
    padding: 1rem;
    color: inherit;
    text-decoration: none;
  }
  .gallery__card-title { font-weight: 600; color: var(--fg); margin-bottom: 0.4rem; }
  .gallery__card-caption { color: var(--fg-muted); font-size: 0.85rem; margin: 0 0 0.6rem; line-height: 1.4; }
  .gallery__card-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .gallery__card[hidden] { display: none; }
</style>

<script>
  import Fuse from 'fuse.js';

  type Card = HTMLElement;
  const grid = document.getElementById('gallery-grid');
  const input = document.getElementById('gallery-search') as HTMLInputElement | null;
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  if (!grid || !input) {
    // hydration noop
  } else {
    const cards = Array.from(grid.querySelectorAll<Card>('.gallery__card'));
    const data = cards.map((c) => ({
      title: c.dataset.title ?? '',
      tags: (c.dataset.tags ?? '').split(' '),
      el: c,
    }));
    const fuse = new Fuse(data, { keys: ['title', 'tags'], threshold: 0.4 });

    let activeTag = 'all';
    let query = '';

    function applyFilter(): void {
      const q = query.trim().toLowerCase();
      const matched = q ? new Set(fuse.search(q).map((r) => r.item.el)) : null;
      data.forEach(({ el, tags }) => {
        const tagOk = activeTag === 'all' || tags.includes(activeTag);
        const queryOk = !matched || matched.has(el);
        el.toggleAttribute('hidden', !(tagOk && queryOk));
      });
    }

    input.addEventListener('input', () => {
      query = input.value;
      applyFilter();
    });
    tagBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        tagBtns.forEach((b) => b.setAttribute('aria-pressed', 'false'));
        btn.setAttribute('aria-pressed', 'true');
        activeTag = btn.dataset.tag ?? 'all';
        applyFilter();
      });
    });
  }
</script>
