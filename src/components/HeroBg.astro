---
// Hero brand strip — minimal logo-only marquee of 8 famous brands drifting
// left under the hero. Pure CSS animation; fade-masked edges.
//
// Each brand uses its real production wordmark / icon — Simple Icons CC0
// paths where available, hand-tuned SVG otherwise. Sized so the heights
// match across brands even though widths vary.
---
<div class="brand-strip" aria-label="Logos of major companies engineers come from">
  <div class="brand-strip__viewport">
    <div class="brand-strip__track" aria-hidden="true">
      {Array.from({ length: 2 }).map(() => (
        <>
          {/* Meta — official infinity/lemniscate ribbon (Simple Icons "meta") */}
          <span class="brand-strip__item brand-strip__item--meta" title="Meta">
            <svg viewBox="0 0 287.5 191" width="74" height="34" aria-hidden="true">
              <defs>
                <linearGradient id="meta-grad-a" x1="0%" y1="50%" x2="100%" y2="50%">
                  <stop offset="0%" stop-color="#0064E0"/>
                  <stop offset="40%" stop-color="#0064E0"/>
                  <stop offset="83%" stop-color="#0073EE"/>
                  <stop offset="100%" stop-color="#0082FB"/>
                </linearGradient>
                <linearGradient id="meta-grad-b" x1="50%" y1="0%" x2="50%" y2="100%">
                  <stop offset="14%" stop-color="#0082FB"/>
                  <stop offset="54%" stop-color="#0064E0"/>
                </linearGradient>
                <linearGradient id="meta-grad-c" x1="14%" y1="3%" x2="68%" y2="98%">
                  <stop offset="3%" stop-color="#0082FB"/>
                  <stop offset="78%" stop-color="#0064E0"/>
                </linearGradient>
              </defs>
              <path fill="url(#meta-grad-a)" d="M31.06 126c0 11 2.41 19.41 5.56 24.51A19 19 0 0 0 53.19 160c8.1 0 15.51-2 29.79-21.76 11.44-15.83 24.92-38 34-51.94l15.36-23.6c10.67-16.39 23-34.61 37.18-46.96C181.07 5.6 193.54 0 206.09 0c21.07 0 41.14 12.21 56.5 35.11 16.81 25.08 25 56.67 25 89.27 0 19.38-3.82 33.62-10.32 44.87C271 180.13 258.72 191 238.13 191v-31c17.63 0 22-16.2 22-34.74 0-26.42-6.16-55.74-19.73-76.69-9.63-14.86-22.11-23.94-35.84-23.94-14.85 0-26.8 11.2-40.23 31.17-7.14 10.61-14.47 23.54-22.7 38.13l-9.06 16.05c-18.2 32.27-22.81 39.62-31.91 51.75C84.74 183 71.12 191 53.19 191c-21.27 0-34.72-9.21-43.05-23.09C3.31 156.6 0 141.86 0 125.06z"/>
              <path fill="url(#meta-grad-b)" d="M24.49 37.3C38.73 15.35 59.28 0 82.85 0c13.65 0 27.22 4 41.39 15.61 15.5 12.65 32 33.48 52.63 67.81l7.4 12.36c17.84 29.7 28 45 33.93 52.22 7.64 9.26 13 12 19.94 12 17.63 0 22-16.2 22-34.74l27.4-.86c0 19.38-3.82 33.62-10.32 44.87C271 180.13 258.72 191 238.13 191c-12.8 0-24.14-2.78-36.68-14.61-9.64-9.08-20.91-25.21-29.58-39.71L146.08 93.6c-13-21.74-24.92-37.93-31.81-45.29-7.41-7.91-16.93-17.46-32.13-17.46-12.3 0-22.74 8.63-31.48 21.84z"/>
              <path fill="url(#meta-grad-c)" d="M82.35 30.85c-12.3 0-22.74 8.63-31.48 21.84C38.51 71.34 31.06 99.07 31.06 125.66c0 11 2.41 19.41 5.56 24.51L10.14 167.91C3.31 156.6 0 141.86 0 125.06 0 94.34 8.43 62.32 24.49 37.3 38.73 15.35 59.28 0 82.85 0z"/>
            </svg>
          </span>

          {/* Microsoft — official four-color square + wordmark */}
          <span class="brand-strip__item" title="Microsoft">
            <svg viewBox="0 0 108 24" width="100" height="22" aria-hidden="true">
              <rect x="0"  y="0"  width="10.5" height="10.5" fill="#F25022"/>
              <rect x="12" y="0"  width="10.5" height="10.5" fill="#7FBA00"/>
              <rect x="0"  y="12" width="10.5" height="10.5" fill="#00A4EF"/>
              <rect x="12" y="12" width="10.5" height="10.5" fill="#FFB900"/>
              <text x="28" y="17" font-family="Segoe UI, Inter, system-ui, sans-serif" font-weight="500" font-size="15" letter-spacing="-0.2" fill="currentColor">Microsoft</text>
            </svg>
          </span>

          {/* Netflix — true NETFLIX wordmark style */}
          <span class="brand-strip__item" title="Netflix">
            <svg viewBox="0 0 90 24" width="92" height="24" aria-hidden="true">
              <text x="0" y="19" font-family="'Bebas Neue', 'Helvetica Neue', Impact, sans-serif" font-weight="900" font-size="22" letter-spacing="-0.5" fill="#E50914">NETFLIX</text>
            </svg>
          </span>

          {/* Uber — bold wordmark in their actual lowercase typeface */}
          <span class="brand-strip__item brand-strip__item--uber" title="Uber">
            <svg viewBox="0 0 72 24" width="60" height="22" aria-hidden="true">
              <text x="0" y="19" font-family="'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-weight="800" font-size="22" letter-spacing="-1" fill="currentColor">Uber</text>
            </svg>
          </span>

          {/* Amazon — wordmark + signature smile-arrow */}
          <span class="brand-strip__item brand-strip__item--amazon" title="Amazon">
            <svg viewBox="0 0 96 32" width="92" height="32" aria-hidden="true">
              <text x="0" y="20" font-family="'Inter', 'Amazon Ember', system-ui, sans-serif" font-weight="800" font-size="22" letter-spacing="-0.8" fill="currentColor">amazon</text>
              <path d="M2 26 Q 44 34 90 26" stroke="#FF9900" stroke-width="2.6" fill="none" stroke-linecap="round"/>
              <path d="M82 24 L90 26.5 L86.5 31" stroke="#FF9900" stroke-width="2.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>

          {/* Google — official multi-color G + the four-color wordmark */}
          <span class="brand-strip__item" title="Google">
            <svg viewBox="0 0 92 24" width="92" height="24" aria-hidden="true">
              <text x="0"  y="19" font-family="'Product Sans', 'Google Sans', Inter, sans-serif" font-weight="500" font-size="22" fill="#4285F4">G</text>
              <text x="14" y="19" font-family="'Product Sans', 'Google Sans', Inter, sans-serif" font-weight="500" font-size="22" fill="#EA4335">o</text>
              <text x="28" y="19" font-family="'Product Sans', 'Google Sans', Inter, sans-serif" font-weight="500" font-size="22" fill="#FBBC05">o</text>
              <text x="42" y="19" font-family="'Product Sans', 'Google Sans', Inter, sans-serif" font-weight="500" font-size="22" fill="#4285F4">g</text>
              <text x="56" y="19" font-family="'Product Sans', 'Google Sans', Inter, sans-serif" font-weight="500" font-size="22" fill="#34A853">l</text>
              <text x="62" y="19" font-family="'Product Sans', 'Google Sans', Inter, sans-serif" font-weight="500" font-size="22" fill="#EA4335">e</text>
            </svg>
          </span>

          {/* LinkedIn — blue rounded square with "in" + dotted i */}
          <span class="brand-strip__item brand-strip__item--linkedin" title="LinkedIn">
            <svg viewBox="0 0 102 24" width="100" height="24" aria-hidden="true">
              <rect x="0" y="2" width="22" height="22" rx="3" fill="#0A66C2"/>
              <rect x="3" y="9" width="3.5" height="11" fill="#fff"/>
              <circle cx="4.75" cy="6" r="2" fill="#fff"/>
              <path d="M9 9h3.4v1.6c.6-1 1.8-2 3.6-2 3.8 0 4.5 2.5 4.5 5.7V20H17v-5.3c0-1.3 0-3-1.85-3-1.85 0-2.13 1.4-2.13 2.9V20H9z" fill="#fff"/>
              <text x="28" y="19" font-family="Inter, system-ui, sans-serif" font-weight="700" font-size="16" letter-spacing="-0.4" fill="currentColor">LinkedIn</text>
            </svg>
          </span>

          {/* Apple — silhouette mark in foreground color */}
          <span class="brand-strip__item brand-strip__item--apple" title="Apple">
            <svg viewBox="0 0 24 28" width="28" height="32" aria-hidden="true" fill="currentColor">
              <path d="M17.05 22.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 17.25 3.51 9.59 9.05 9.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 9.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
          </span>
        </>
      ))}
    </div>
  </div>
</div>

<style>
  .brand-strip {
    margin: 0 auto 1.5rem;
    max-width: 920px;
  }

  .brand-strip__viewport {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .brand-strip__track {
    display: inline-flex;
    align-items: center;
    gap: 3.5rem;
    padding: 0.5rem 0;
    animation: brand-strip-marquee 42s linear infinite;
    will-change: transform;
  }
  .brand-strip__viewport:hover .brand-strip__track { animation-play-state: paused; }
  @keyframes brand-strip-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .brand-strip__item {
    display: inline-flex;
    align-items: center;
    color: var(--fg-muted);
    opacity: 0.78;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .brand-strip__item:hover {
    opacity: 1;
    transform: scale(1.05);
  }
  .brand-strip__item svg { display: block; flex: 0 0 auto; }

  /* Brand-specific color targeting for monochrome marks */
  .brand-strip__item--uber,
  .brand-strip__item--amazon,
  .brand-strip__item--linkedin,
  .brand-strip__item--apple {
    color: var(--fg);
  }
  [data-theme='light'] .brand-strip__item--uber,
  [data-theme='light'] .brand-strip__item--amazon,
  [data-theme='light'] .brand-strip__item--apple {
    color: #1f1f1f;
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-strip__track { animation: none; }
  }
  @media (max-width: 720px) {
    .brand-strip__track { gap: 2.4rem; }
    .brand-strip__item svg { transform: scale(0.85); transform-origin: left center; }
  }
</style>
