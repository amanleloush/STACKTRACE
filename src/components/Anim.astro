---
interface Props {
  id: string;
  /** Optional per-instance options passed via data-* attributes (numbers parsed). */
  opts?: Record<string, string | number | boolean>;
  /** Render only the inner host (no extra margin) — used on standalone pages. */
  bare?: boolean;
}
const { id, opts = {}, bare = false } = Astro.props;
const dataAttrs: Record<string, string> = { 'data-anim': id };
for (const [k, v] of Object.entries(opts)) {
  dataAttrs[`data-${k}`] = String(v);
}
---
<div {...dataAttrs} class={bare ? '' : 'anim-host'}></div>

<script>
  // Ensures the mount runtime is loaded once per page. The runtime itself is
  // idempotent (mountOne is a no-op for already-mounted hosts).
  import '~/lib/anim/mount';
</script>
