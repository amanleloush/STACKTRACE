---
import { getCollection, type CollectionEntry } from 'astro:content';

interface PhaseGroup {
  phase: string;
  label: string;
  nodes: Array<{
    slug: string;
    title: string;
    order: number;
    premium: boolean;
    summary?: string;
    estimatedMinutes?: number;
  }>;
}

function phaseLabel(slug: string): string {
  return slug
    .replace(/^[0-9]+-/, '')
    .replace(/-/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

function groupBy<T extends CollectionEntry<'notes'> | CollectionEntry<'dsa'>>(entries: T[]): PhaseGroup[] {
  const m = new Map<string, T[]>();
  for (const e of entries) {
    const arr = m.get(e.data.phase) ?? [];
    arr.push(e);
    m.set(e.data.phase, arr);
  }
  return [...m.keys()]
    .sort()
    .map((phase) => {
      const items = m.get(phase)!.sort((a, b) => a.data.order - b.data.order);
      return {
        phase,
        label: phaseLabel(phase),
        nodes: items.map((e) => ({
          slug: e.id,
          title: e.data.title,
          order: e.data.order,
          premium: e.data.premium,
          summary: e.data.summary,
          estimatedMinutes: e.data.estimatedMinutes,
        })),
      };
    });
}

const systemsEntries = (await getCollection('notes', (n) => !n.data.draft));
const dsaEntries = (await getCollection('dsa', (n) => !n.data.draft));

const systems = groupBy(systemsEntries);
const dsa = groupBy(dsaEntries);

interface Props {
  initial?: 'systems' | 'dsa';
}
const { initial = 'systems' } = Astro.props;
---
<section class="roadmap" data-pillar={initial}>
  <header class="roadmap__head">
    <div class="roadmap__toggle" role="tablist" aria-label="Roadmap pillar">
      <button
        type="button"
        class="roadmap__tab"
        role="tab"
        aria-selected={initial === 'systems'}
        data-target="systems"
      >
        Systems
        <span class="roadmap__count">{systemsEntries.length}</span>
      </button>
      <button
        type="button"
        class="roadmap__tab"
        role="tab"
        aria-selected={initial === 'dsa'}
        data-target="dsa"
      >
        DSA
        <span class="roadmap__count">{dsaEntries.length}</span>
      </button>
    </div>
    <p class="roadmap__hint">
      Each chip is a topic. Click to open the note + animation.
    </p>
  </header>

  {(['systems', 'dsa'] as const).map((pillar) => {
    const phases = pillar === 'systems' ? systems : dsa;
    const linkBase = pillar === 'systems' ? '/learn/notes' : '/learn/dsa';
    return (
      <div
        class={`roadmap__pillar roadmap__pillar--${pillar}`}
        role="tabpanel"
        aria-label={`${pillar} roadmap`}
      >
        {phases.length === 0 ? (
          <p class="roadmap__empty">
            Coming soon — DSA pillar is still being built out.
          </p>
        ) : (
          phases.map((phase) => (
            <section class="roadmap__phase">
              <h3 class="roadmap__phase-label">{phase.label}</h3>
              <ul class="roadmap__chips">
                {phase.nodes.map((n) => (
                  <li>
                    <a
                      class="roadmap__chip"
                      href={`${linkBase}/${n.slug}/`}
                      data-premium={n.premium ? 'true' : undefined}
                      title={n.summary ?? n.title}
                    >
                      <span class="roadmap__chip-order">{String(n.order).padStart(2, '0')}</span>
                      <span class="roadmap__chip-title">{n.title}</span>
                      {n.premium && <span class="roadmap__chip-lock" aria-label="Premium">🔒</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        )}
      </div>
    );
  })}
</section>

<style>
  .roadmap { margin: 1.5rem 0; }
  .roadmap__head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .roadmap__toggle {
    display: inline-flex;
    background: var(--bg-soft);
    border: 1px solid var(--card-border);
    border-radius: 999px;
    padding: 4px;
    width: fit-content;
    gap: 4px;
  }
  .roadmap__tab {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--fg-muted);
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    font: inherit;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    transition: background 0.15s, color 0.15s;
  }
  .roadmap__tab[aria-selected="true"] { background: var(--primary); color: white; }
  .roadmap__count {
    background: color-mix(in srgb, currentColor 18%, transparent);
    font-size: 0.7rem;
    padding: 0.05rem 0.45rem;
    border-radius: 999px;
    font-weight: 700;
  }
  .roadmap__hint { color: var(--fg-faint); font-size: 0.85rem; margin: 0; }

  /* Pillar visibility — JS-free swap via data-pillar on the root. */
  .roadmap[data-pillar="systems"] .roadmap__pillar--dsa,
  .roadmap[data-pillar="dsa"] .roadmap__pillar--systems { display: none; }

  .roadmap__phase {
    border-top: 1px solid var(--card-border);
    padding: 1rem 0 1.25rem;
  }
  .roadmap__phase:first-child { border-top: none; padding-top: 0.25rem; }
  .roadmap__phase-label {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: var(--fg-muted);
  }
  .roadmap__chips {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .roadmap__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    color: var(--fg);
    padding: 0.55rem 0.85rem;
    border-radius: 10px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition: transform 0.12s, border-color 0.12s, background 0.12s;
    max-width: 22rem;
  }
  .roadmap__chip:hover {
    transform: translateY(-1px);
    border-color: var(--primary-light);
    background: color-mix(in srgb, var(--primary) 8%, var(--card-bg));
    text-decoration: none;
  }
  .roadmap__chip-order {
    font-family: var(--font-code);
    font-size: 0.75rem;
    color: var(--fg-faint);
  }
  .roadmap__chip-title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 18rem; }
  .roadmap__chip-lock { font-size: 0.75rem; }
  .roadmap__empty { color: var(--fg-muted); font-style: italic; }

  @media (max-width: 540px) {
    .roadmap__chip { max-width: 100%; }
    .roadmap__chip-title { max-width: 14rem; }
  }
</style>

<script>
  // Minimal pillar-toggle script — only thing on this page that needs JS.
  // The actual show/hide is CSS-only via the data-pillar attribute.
  const roadmaps = document.querySelectorAll<HTMLElement>('.roadmap');
  for (const root of roadmaps) {
    const tabs = root.querySelectorAll<HTMLButtonElement>('.roadmap__tab');
    for (const tab of tabs) {
      tab.addEventListener('click', () => {
        const target = tab.dataset.target;
        if (!target) return;
        root.dataset.pillar = target;
        for (const t of tabs) {
          t.setAttribute('aria-selected', String(t === tab));
        }
      });
    }
  }
</script>
