---
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatPhaseLabel } from '~/lib/phase-label';

interface PhaseGroup {
  phase: string;
  num: string;
  label: string;
  nodes: Array<{
    slug: string;
    title: string;
    order: number;
    premium: boolean;
    summary?: string;
    estimatedMinutes?: number;
  }>;
}

function phaseNum(slug: string): string {
  const m = slug.match(/^(\d+)-/);
  return m ? m[1] : '··';
}

function groupBy<T extends CollectionEntry<'notes'> | CollectionEntry<'dsa'>>(entries: T[]): PhaseGroup[] {
  const m = new Map<string, T[]>();
  for (const e of entries) {
    const arr = m.get(e.data.phase) ?? [];
    arr.push(e);
    m.set(e.data.phase, arr);
  }
  return [...m.keys()]
    .sort()
    .map((phase) => {
      const items = m.get(phase)!.sort((a, b) => a.data.order - b.data.order);
      return {
        phase,
        num: phaseNum(phase),
        label: formatPhaseLabel(phase),
        nodes: items.map((e) => ({
          slug: e.id,
          title: e.data.title,
          order: e.data.order,
          premium: e.data.premium,
          summary: e.data.summary,
          estimatedMinutes: e.data.estimatedMinutes,
        })),
      };
    });
}

const systemsEntries = (await getCollection('notes', (n) => !n.data.draft));
const dsaEntries = (await getCollection('dsa', (n) => !n.data.draft));

const systems = groupBy(systemsEntries);
const dsa = groupBy(dsaEntries);

interface Props {
  initial?: 'systems' | 'dsa';
}
const { initial = 'systems' } = Astro.props;
---
<section class="roadmap" data-pillar={initial}>
  <header class="roadmap__head">
    <div class="roadmap__toggle" role="tablist" aria-label="Roadmap pillar">
      <button
        type="button"
        class="roadmap__tab"
        role="tab"
        aria-selected={initial === 'systems'}
        data-target="systems"
      >
        Systems
        <span class="roadmap__count">{systemsEntries.length}</span>
      </button>
      <button
        type="button"
        class="roadmap__tab"
        role="tab"
        aria-selected={initial === 'dsa'}
        data-target="dsa"
      >
        DSA
        <span class="roadmap__count">{dsaEntries.length}</span>
      </button>
    </div>
    <p class="roadmap__hint">
      Drive the whole journey, station by station. Each marker is a phase; each tag is one note + animation.
    </p>
  </header>

  {(['systems', 'dsa'] as const).map((pillar) => {
    const phases = pillar === 'systems' ? systems : dsa;
    const linkBase = pillar === 'systems' ? '/learn/notes' : '/learn/dsa';
    // Storage-key prefix MUST match what NoteCompletion writes — that
    // component uses 'notes' for system-design notes and 'dsa' for DSA.
    // Without this alias the roadmap never marks systems-pillar chips done.
    const keyPrefix = pillar === 'systems' ? 'notes' : 'dsa';
    return (
      <div
        class={`roadmap__pillar roadmap__pillar--${pillar}`}
        role="tabpanel"
        aria-label={`${pillar} roadmap`}
      >
        {phases.length === 0 ? (
          <p class="roadmap__empty">
            Coming soon — this pillar is still being built out.
          </p>
        ) : (
          <div class="road" data-pillar={pillar}>
            <span class="road__line" aria-hidden="true"></span>
            {phases.map((phase, idx) => (
              <article
                class={`road__stop road__stop--${idx % 2 === 0 ? 'left' : 'right'}`}
                data-phase={phase.phase}
                data-expanded={idx === 0 ? 'true' : 'false'}
                data-total={phase.nodes.length}
              >
                <span class="road__marker" aria-hidden="true">
                  <span class="road__marker-num">{phase.num}</span>
                  <span class="road__marker-check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m6 12 4 4 8-9" />
                    </svg>
                  </span>
                </span>
                <div class="road__card">
                  <button
                    type="button"
                    class="road__card-head"
                    aria-expanded={idx === 0 ? 'true' : 'false'}
                    aria-controls={`road-body-${pillar}-${phase.phase}`}
                  >
                    <h3 class="road__card-title">{phase.label}</h3>
                    <span class="road__progress">
                      <span class="road__progress-fraction">
                        <span class="road__progress-done">0</span>
                        <span class="road__progress-divider">/</span>
                        <span class="road__progress-total">{phase.nodes.length}</span>
                      </span>
                      <span class="road__progress-complete">All done ✓</span>
                    </span>
                    <span class="road__chevron" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m6 9 6 6 6-6" />
                      </svg>
                    </span>
                  </button>
                  <ul
                    class="road__chips"
                    id={`road-body-${pillar}-${phase.phase}`}
                  >
                    {phase.nodes.map((n) => (
                      <li>
                        <a
                          class="road__chip"
                          href={`${linkBase}/${n.slug}/`}
                          data-key={`${keyPrefix}:${n.slug}`}
                          data-premium={n.premium ? 'true' : undefined}
                          title={n.summary ?? n.title}
                        >
                          <span class="road__chip-check" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                              <path d="m6 12 4 4 8-9" />
                            </svg>
                          </span>
                          <span class="road__chip-order">{String(n.order).padStart(2, '0')}</span>
                          <span class="road__chip-title">{n.title}</span>
                          {n.premium && <span class="road__chip-lock" aria-label="Premium">🔒</span>}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))}
            <div class="road__end" aria-hidden="true">
              <span class="road__end-flag">🏁</span>
              <span class="road__end-label">Journey complete</span>
            </div>
          </div>
        )}
      </div>
    );
  })}
</section>

<style>
  .roadmap { margin: 1.5rem 0 4rem; }
  .roadmap__head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    align-items: center;
    text-align: center;
  }
  /* Full-width segmented toggle, sliding pill indicator. */
  .roadmap__toggle {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--bg-soft);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 6px;
    width: 100%;
    max-width: 480px;
  }
  .roadmap__toggle::before {
    content: '';
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 6px;
    width: calc(50% - 6px);
    border-radius: 12px;
    background: linear-gradient(135deg, var(--primary-dark, var(--primary)) 0%, var(--primary) 100%);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--primary) 35%, transparent);
    transition: transform 0.45s cubic-bezier(0.6, -0.05, 0.3, 1.4);
    z-index: 0;
  }
  .roadmap[data-pillar='dsa'] .roadmap__toggle::before {
    transform: translateX(100%);
  }
  .roadmap__tab {
    appearance: none;
    position: relative;
    z-index: 1;
    border: none;
    background: transparent;
    color: var(--fg-muted);
    padding: 0.7rem 1rem;
    border-radius: 12px;
    font: inherit;
    font-weight: 700;
    font-size: 0.92rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: color 0.3s ease;
  }
  .roadmap__tab[aria-selected="true"] { color: white; }
  .roadmap__count {
    background: color-mix(in srgb, currentColor 18%, transparent);
    font-size: 0.7rem;
    padding: 0.05rem 0.5rem;
    border-radius: 999px;
    font-weight: 700;
  }
  .roadmap__hint { color: var(--fg-muted); font-size: 0.9rem; margin: 0; max-width: 36rem; }

  .roadmap[data-pillar="systems"] .roadmap__pillar--dsa,
  .roadmap[data-pillar="dsa"] .roadmap__pillar--systems { display: none; }

  /* Animated pillar enter — same recipe as the landing-page journey */
  .roadmap__pillar {
    animation: roadmap-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .roadmap__pillar .road__stop {
    animation: roadmap-stop-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) backwards;
  }
  .roadmap__pillar .road__stop:nth-child(2)  { animation-delay: 0.05s; }
  .roadmap__pillar .road__stop:nth-child(3)  { animation-delay: 0.08s; }
  .roadmap__pillar .road__stop:nth-child(4)  { animation-delay: 0.11s; }
  .roadmap__pillar .road__stop:nth-child(5)  { animation-delay: 0.14s; }
  .roadmap__pillar .road__stop:nth-child(6)  { animation-delay: 0.17s; }
  .roadmap__pillar .road__stop:nth-child(7)  { animation-delay: 0.20s; }
  .roadmap__pillar .road__stop:nth-child(8)  { animation-delay: 0.23s; }
  .roadmap__pillar .road__stop:nth-child(n+9) { animation-delay: 0.26s; }
  @keyframes roadmap-enter {
    0%   { opacity: 0; transform: translateY(12px) scale(0.99); filter: blur(4px); }
    60%  { opacity: 1; filter: blur(0); }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
  }
  @keyframes roadmap-stop-pop {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .roadmap__toggle::before { transition: none; }
    .roadmap__pillar,
    .roadmap__pillar .road__stop { animation: none; }
  }
  .roadmap__empty {
    color: var(--fg-muted);
    font-style: italic;
    padding: 2rem;
    border: 1px dashed var(--card-border);
    border-radius: 12px;
    text-align: center;
  }

  /* ============================================================
     The road — a vertical timeline rendered as a stylized highway.
     Background dotted grid evokes a paper map; the road itself is
     a gradient strip running down the centre; phase markers sit
     ON the road; phase cards alternate left/right like landmarks.
     ============================================================ */
  .road {
    position: relative;
    padding: 1.5rem 0 4rem;
    max-width: 1080px;
    margin: 0 auto;
    background-image:
      radial-gradient(circle at center, color-mix(in srgb, var(--fg-muted) 18%, transparent) 1px, transparent 1.5px);
    background-size: 28px 28px;
    background-position: 0 0;
    border-radius: 18px;
  }

  /* The road itself — a thick vertical gradient strip with dashed center line */
  .road__line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 14px;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--accent) 35%, transparent),
      color-mix(in srgb, var(--accent) 55%, transparent) 8%,
      color-mix(in srgb, var(--accent) 55%, transparent) 92%,
      color-mix(in srgb, var(--accent) 35%, transparent)
    );
    border-radius: 7px;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent) 30%, transparent),
      0 0 30px color-mix(in srgb, var(--accent) 22%, transparent);
    z-index: 1;
  }
  .road__line::before {
    /* Dashed centre lane stripe */
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    background-image: repeating-linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.6) 0,
      rgba(255, 255, 255, 0.6) 14px,
      transparent 14px,
      transparent 28px
    );
    opacity: 0.55;
  }

  /* A single stop — marker on the line + a phase card to one side */
  .road__stop {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 80px 1fr;
    align-items: start;
    margin-bottom: 2.5rem;
    z-index: 2;
  }
  .road__stop:last-of-type { margin-bottom: 0; }

  .road__marker {
    grid-column: 2;
    justify-self: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--grad-3);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 800;
    font-family: var(--font-code);
    font-size: 1rem;
    box-shadow:
      0 0 0 6px color-mix(in srgb, var(--bg) 80%, transparent),
      0 0 0 7px color-mix(in srgb, var(--accent) 40%, transparent),
      0 8px 24px color-mix(in srgb, var(--accent) 28%, transparent);
    position: relative;
    transition: background 0.25s ease, box-shadow 0.25s ease;
  }
  .road__marker-num {
    background: rgba(255, 255, 255, 0.18);
    padding: 0.2rem 0.55rem;
    border-radius: 7px;
    letter-spacing: 0.04em;
    transition: opacity 0.25s ease;
  }
  .road__marker-check {
    position: absolute;
    inset: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.7);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .road__stop[data-complete='true'] .road__marker {
    background: linear-gradient(135deg, var(--anim-success, var(--accent)) 0%, var(--accent) 100%);
    box-shadow:
      0 0 0 6px color-mix(in srgb, var(--bg) 80%, transparent),
      0 0 0 7px color-mix(in srgb, var(--anim-success, var(--accent)) 60%, transparent),
      0 8px 24px color-mix(in srgb, var(--anim-success, var(--accent)) 35%, transparent);
  }
  .road__stop[data-complete='true'] .road__marker-num { opacity: 0; }
  .road__stop[data-complete='true'] .road__marker-check {
    opacity: 1;
    transform: scale(1);
  }

  /* Card alternates side. A short connector arm joins it to the marker. */
  .road__card {
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 1rem 1.15rem 1.15rem;
    box-shadow: var(--card-shadow);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .road__stop--left .road__card {
    grid-column: 1;
    margin-right: 1.5rem;
    text-align: right;
  }
  .road__stop--right .road__card {
    grid-column: 3;
    margin-left: 1.5rem;
  }
  /* Connector arm from card to marker */
  .road__card::after {
    content: '';
    position: absolute;
    top: 28px;
    width: 28px;
    height: 2px;
    background: color-mix(in srgb, var(--accent) 60%, transparent);
  }
  .road__stop--left .road__card::after { right: -28px; }
  .road__stop--right .road__card::after { left: -28px; }

  .road__card-head {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin: -0.4rem -0.5rem 0.85rem;
    padding: 0.55rem 0.6rem;
    width: calc(100% + 1rem);
    background: transparent;
    border: none;
    border-radius: 8px;
    color: inherit;
    cursor: pointer;
    font: inherit;
    text-align: left;
    transition: background 0.15s ease;
  }
  .road__card-head:hover {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .road__card-head:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .road__stop--left .road__card-head { flex-direction: row-reverse; text-align: right; }
  .road__stop--left .road__card-head .road__chevron { margin-right: 0; }

  .road__card-title {
    margin: 0;
    font-size: 1.05rem;
    background: var(--grad-3);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    flex: 1 1 auto;
  }

  .road__progress {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-code);
    font-size: 0.72rem;
    color: var(--fg-muted);
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }
  .road__progress-fraction { display: inline-flex; align-items: baseline; gap: 0.1rem; }
  .road__progress-done { color: var(--accent); }
  .road__progress-divider { color: var(--fg-faint); }
  .road__progress-complete { display: none; color: var(--anim-success, var(--accent)); }
  .road__stop[data-complete='true'] .road__progress {
    background: color-mix(in srgb, var(--anim-success, var(--accent)) 15%, transparent);
    border-color: color-mix(in srgb, var(--anim-success, var(--accent)) 55%, transparent);
  }
  .road__stop[data-complete='true'] .road__progress-fraction { display: none; }
  .road__stop[data-complete='true'] .road__progress-complete { display: inline; }

  .road__chevron {
    flex: 0 0 auto;
    display: inline-flex;
    color: var(--fg-faint);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .road__card-head:hover .road__chevron { color: var(--accent); }
  .road__stop[data-expanded='true'] .road__chevron { transform: rotate(180deg); }

  /* Topic chips inside a phase card — hidden when phase is collapsed */
  .road__chips {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    max-height: 1000px;
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.25s ease, margin 0.25s ease;
  }
  .road__stop[data-expanded='false'] .road__chips {
    max-height: 0;
    opacity: 0;
    margin-top: -0.85rem;
  }
  .road__stop--left .road__chips { justify-content: flex-end; }
  .road__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: color-mix(in srgb, var(--accent) 6%, var(--bg-soft));
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--card-border));
    color: var(--fg);
    padding: 0.4rem 0.7rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    transition: transform 0.12s, border-color 0.12s, background 0.12s;
  }
  .road__chip:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, var(--bg-soft));
    text-decoration: none;
  }
  .road__chip-order { font-family: var(--font-code); font-size: 0.7rem; color: var(--fg-faint); }
  .road__chip-title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 14rem; }
  .road__chip-lock { font-size: 0.75rem; }
  .road__chip-check {
    display: none;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--anim-success, var(--accent));
    color: white;
    flex: 0 0 auto;
    margin-right: -0.1rem;
  }
  .road__chip[data-done='true'] .road__chip-check { display: inline-flex; }
  .road__chip[data-done='true'] {
    background: color-mix(in srgb, var(--anim-success, var(--accent)) 12%, var(--bg-soft));
    border-color: color-mix(in srgb, var(--anim-success, var(--accent)) 55%, transparent);
  }
  .road__chip[data-done='true'] .road__chip-title { color: var(--fg-muted); text-decoration: line-through; text-decoration-color: color-mix(in srgb, var(--fg-muted) 40%, transparent); text-decoration-thickness: 1px; }

  /* End marker — checkered flag at the bottom of the road */
  .road__end {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .road__end-flag {
    font-size: 2.4rem;
    filter: drop-shadow(0 4px 12px color-mix(in srgb, var(--accent) 35%, transparent));
  }
  .road__end-label {
    font-family: var(--font-code);
    font-size: 0.72rem;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Tablet — pull the cards a bit closer */
  @media (max-width: 960px) {
    .road__stop { grid-template-columns: 1fr 64px 1fr; }
    .road__marker { width: 48px; height: 48px; font-size: 0.9rem; }
  }

  /* Mobile — collapse to single column with road on the LEFT, cards on the right */
  @media (max-width: 720px) {
    .road {
      background-size: 22px 22px;
      padding: 1rem 0 3rem;
    }
    .road__line {
      left: 36px;
      transform: none;
      width: 10px;
      border-radius: 5px;
    }
    .road__stop {
      grid-template-columns: 72px 1fr;
      margin-bottom: 1.5rem;
    }
    .road__marker {
      grid-column: 1;
      width: 44px;
      height: 44px;
      font-size: 0.85rem;
      justify-self: center;
      box-shadow:
        0 0 0 4px var(--bg),
        0 0 0 5px color-mix(in srgb, var(--accent) 40%, transparent),
        0 6px 18px color-mix(in srgb, var(--accent) 25%, transparent);
    }
    .road__stop--left .road__card,
    .road__stop--right .road__card {
      grid-column: 2;
      margin: 0 0.75rem 0 0;
      text-align: left;
      padding: 0.85rem 1rem;
    }
    .road__stop--left .road__card-head,
    .road__stop--left .road__chips {
      justify-content: flex-start;
    }
    .road__card::after {
      top: 22px;
      width: 16px;
    }
    .road__stop--left .road__card::after,
    .road__stop--right .road__card::after { left: -16px; right: auto; }
    .road__chip-title { max-width: 12rem; }
    .road__end { align-items: flex-start; padding-left: 18px; }
  }
</style>

<script>
  // -------- Pillar toggle (Systems ↔ DSA) --------
  const roadmaps = document.querySelectorAll<HTMLElement>('.roadmap');
  for (const root of roadmaps) {
    const tabs = root.querySelectorAll<HTMLButtonElement>('.roadmap__tab');
    for (const tab of tabs) {
      tab.addEventListener('click', () => {
        const target = tab.dataset.target;
        if (!target) return;
        root.dataset.pillar = target;
        for (const t of tabs) {
          t.setAttribute('aria-selected', String(t === tab));
        }
      });
    }
  }

  // -------- Per-phase expand/collapse --------
  document.querySelectorAll<HTMLButtonElement>('.road__card-head').forEach((head) => {
    head.addEventListener('click', () => {
      const stop = head.closest<HTMLElement>('.road__stop');
      if (!stop) return;
      const open = stop.dataset.expanded === 'true';
      stop.dataset.expanded = open ? 'false' : 'true';
      head.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
  });

  // -------- Progress wiring (localStorage-backed) --------
  function readCompleted(): Set<string> {
    try {
      return new Set(JSON.parse(localStorage.getItem('stacktrace:completed') ?? '[]'));
    } catch {
      return new Set();
    }
  }

  function paintProgress(): void {
    const done = readCompleted();
    document.querySelectorAll<HTMLElement>('.road__stop').forEach((stop) => {
      const chips = stop.querySelectorAll<HTMLAnchorElement>('.road__chip[data-key]');
      let completedHere = 0;
      chips.forEach((chip) => {
        const key = chip.dataset.key;
        const isDone = !!key && done.has(key);
        chip.dataset.done = isDone ? 'true' : 'false';
        if (isDone) completedHere++;
      });
      const total = chips.length;
      const doneEl = stop.querySelector<HTMLElement>('.road__progress-done');
      const totalEl = stop.querySelector<HTMLElement>('.road__progress-total');
      if (doneEl) doneEl.textContent = String(completedHere);
      if (totalEl) totalEl.textContent = String(total);
      stop.dataset.complete = completedHere === total && total > 0 ? 'true' : 'false';
    });
  }

  paintProgress();
  window.addEventListener('stacktrace:progress', paintProgress);
  window.addEventListener('storage', (e) => {
    if (e.key === 'stacktrace:completed') paintProgress();
  });
</script>
