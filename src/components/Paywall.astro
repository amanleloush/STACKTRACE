---
/**
 * Two-mode paywall. Only ever rendered from SSR routes (the /learn/*
 * pages and the runtime <Premium> block), so reading Astro.locals.user
 * is safe here — no `request.headers` warning.
 */
interface Props {
  reason: 'note' | 'block';
  /** Optional CTA next-link for the post-checkout redirect. */
  next?: string;
}
const { reason, next = Astro.url.pathname } = Astro.props;
const user = Astro.locals.user;
const signedIn = user != null;
const checkoutHref = `/pricing/?next=${encodeURIComponent(next)}`;
const signInHref = `/login/?next=${encodeURIComponent(next)}`;
---
<aside class={`paywall paywall--${reason}`} role="status" aria-live="polite">
  {reason === 'note' ? (
    <>
      <div class="paywall__chip">🔒 Premium</div>
      <h2 class="paywall__title">This note is part of the premium track</h2>
      {signedIn ? (
        <p class="paywall__sub">
          You're signed in as <strong>{user!.email}</strong>, but your tier doesn't
          include this note. Upgrade to unlock the full body — every animation,
          code block, and trade-off table — across every premium note.
        </p>
      ) : (
        <p class="paywall__sub">
          Subscribe to read the full body — every animation, every code block,
          every cheat-sheet — across all premium notes.
        </p>
      )}
      <div class="paywall__cta">
        <a class="anim__btn anim__btn--primary" href={checkoutHref}>
          {signedIn ? 'Upgrade to premium' : 'See pricing'}
        </a>
        {signedIn ? (
          <a class="anim__btn" href="/account/">Account settings</a>
        ) : (
          <a class="anim__btn" href={signInHref}>Already a member? Sign in</a>
        )}
      </div>
    </>
  ) : (
    <span class="paywall__inline">
      🔒 Premium section —
      <a href={signedIn ? checkoutHref : signInHref}>
        {signedIn ? 'upgrade' : 'sign in'}
      </a>
    </span>
  )}
</aside>

<style>
  .paywall--note {
    margin: 2rem 0;
    padding: 1.5rem 1.5rem 1.75rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .paywall--note::before {
    content: "";
    position: absolute;
    top: -40px; right: -40px;
    width: 200px; height: 200px;
    background: var(--grad-5);
    filter: blur(80px);
    opacity: 0.2;
    z-index: 0;
  }
  .paywall--note > * { position: relative; z-index: 1; }
  .paywall__chip {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    background: var(--grad-5);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
  }
  .paywall__title { margin: 0 0 0.5rem; font-size: 1.2rem; }
  .paywall__sub { color: var(--fg-muted); max-width: 32rem; margin: 0 auto 1.25rem; font-size: 0.92rem; }
  .paywall__sub strong { color: var(--fg); }
  .paywall__cta { display: inline-flex; gap: 0.6rem; flex-wrap: wrap; justify-content: center; }

  .paywall--block {
    margin: 1rem 0;
    padding: 0.75rem 1rem;
    border: 1px dashed var(--card-border);
    border-radius: 10px;
    background: color-mix(in srgb, var(--primary) 5%, transparent);
    font-size: 0.88rem;
  }
  .paywall__inline a {
    color: var(--primary-light);
    font-weight: 600;
    margin-left: 0.3rem;
  }
</style>
