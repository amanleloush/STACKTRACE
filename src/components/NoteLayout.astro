---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'notes'> | CollectionEntry<'dsa'>;
  collectionLabel?: string; // "Notes" | "DSA"
}
const { entry, collectionLabel = 'Notes' } = Astro.props;
const fm = entry.data;
const phaseLabel = fm.phase
  .replace(/^[0-9]+-/, '')
  .replace(/-/g, ' ')
  .replace(/\b\w/g, (c) => c.toUpperCase());
---
<article class="note">
  <nav class="note__crumbs" aria-label="Breadcrumb">
    <a href="/notes/">{collectionLabel}</a>
    <span aria-hidden="true">›</span>
    <span>{phaseLabel}</span>
  </nav>

  <header class="note__head">
    <h1 class="note__title">{fm.title}</h1>
    <div class="note__meta">
      {fm.estimatedMinutes && (
        <span class="note__minutes">{fm.estimatedMinutes} min read</span>
      )}
      {fm.tags && fm.tags.length > 0 && (
        <div class="note__tags">
          {fm.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
      {fm.premium && (
        <span class="note__lock" title="Premium content">🔒 Premium</span>
      )}
    </div>
    {fm.summary && <p class="note__summary">{fm.summary}</p>}
  </header>

  <div class="note__body">
    <slot />
  </div>

  {fm.prerequisites && fm.prerequisites.length > 0 && (
    <footer class="note__prereqs">
      <h4>Prerequisites</h4>
      <ul>
        {fm.prerequisites.map((slug) => (
          <li><a href={`/learn/notes/${slug}/`}>{slug}</a></li>
        ))}
      </ul>
    </footer>
  )}
</article>

<style>
  .note { max-width: 48rem; margin: 0 auto; }
  .note__crumbs {
    font-size: 0.85rem;
    color: var(--fg-muted);
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  .note__crumbs a { color: var(--fg-muted); }
  .note__head { margin-bottom: 2rem; }
  .note__title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0 0 0.75rem;
  }
  .note__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    color: var(--fg-muted);
    font-size: 0.85rem;
  }
  .note__minutes {
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    color: var(--primary-light);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-weight: 600;
  }
  .note__tags { display: inline-flex; gap: 0.3rem; flex-wrap: wrap; }
  .note__lock {
    background: var(--grad-5);
    color: white;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .note__summary {
    color: var(--fg-muted);
    margin: 1rem 0 0;
    font-style: italic;
    font-size: 1rem;
  }
  .note__body :global(h2) { margin-top: 2.5rem; }
  .note__body :global(h3) { margin-top: 2rem; }
  .note__body :global(ul), .note__body :global(ol) {
    line-height: 1.7;
    padding-left: 1.5rem;
  }
  .note__body :global(blockquote) {
    border-left: 3px solid var(--primary);
    padding: 0.4rem 1rem;
    margin: 1.5rem 0;
    color: var(--fg-muted);
    background: color-mix(in srgb, var(--primary) 8%, transparent);
    border-radius: 0 6px 6px 0;
  }
  .note__prereqs {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--card-border);
  }
  .note__prereqs h4 { margin: 0 0 0.5rem; color: var(--fg-muted); font-weight: 600; }
  .note__prereqs ul { margin: 0; padding-left: 1.25rem; }
</style>
