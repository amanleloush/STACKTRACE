---
import { getCollection, type CollectionEntry } from 'astro:content';
import NoteCompletion from './NoteCompletion.astro';
import { formatPhaseLabel } from '~/lib/phase-label';

interface Props {
  entry: CollectionEntry<'notes'> | CollectionEntry<'dsa'>;
  collectionLabel?: string; // "System Design" | "DSA"
  /** Effective gate state from the entitlement system — overrides
   *  fm.premium for the 🔒 badge. Optional; defaults to fm.premium. */
  effectivePremium?: boolean;
}
const { entry, collectionLabel = 'System Design', effectivePremium } = Astro.props;
const fm = entry.data;
const showLock = effectivePremium ?? fm.premium;
const phaseLabel = formatPhaseLabel(fm.phase);
// Prerequisite links + the breadcrumb root depend on which collection
// we're in. NoteLayout is the only place that bridges between pillars.
const isDsa = entry.collection === 'dsa';
const pillarRoute = isDsa ? '/learn/dsa' : '/learn/notes';
const tocRoute = isDsa ? '/dsa/' : '/notes/';
const progressPillar = isDsa ? 'dsa' : 'notes';

// Compute the next entry: same collection + same phase + next-highest
// order. If we're already last in the phase, fall back to the first
// entry of the next phase (alphabetical phase-slug order). Used by
// NoteCompletion to surface a "Next topic →" CTA after marking done.
const collectionName = isDsa ? 'dsa' : 'notes';
const peers = (await getCollection(collectionName, (n) => !n.data.draft)) as
  Array<CollectionEntry<'notes' | 'dsa'>>;
peers.sort((a, b) => {
  if (a.data.phase !== b.data.phase) return a.data.phase.localeCompare(b.data.phase);
  return a.data.order - b.data.order;
});
const here = peers.findIndex((p) => p.id === entry.id);
const next = here >= 0 && here < peers.length - 1 ? peers[here + 1] : null;
const nextHref = next ? `${pillarRoute}/${next.id}/` : null;
const nextTitle = next?.data.title ?? null;
---
<article class="note">
  <nav class="note__crumbs" aria-label="Breadcrumb">
    <a href={tocRoute}>{collectionLabel}</a>
    <span aria-hidden="true">›</span>
    <span>{phaseLabel}</span>
  </nav>

  <header class="note__head">
    <h1 class="note__title">{fm.title}</h1>
    <div class="note__meta">
      {fm.estimatedMinutes && (
        <span class="note__minutes">{fm.estimatedMinutes} min read</span>
      )}
      {fm.tags && fm.tags.length > 0 && (
        <div class="note__tags">
          {fm.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
      {showLock && (
        <span class="note__lock" title="Premium content">🔒 Premium</span>
      )}
    </div>
    {fm.summary && <p class="note__summary">{fm.summary}</p>}
  </header>

  <div class="note__body">
    <slot />
  </div>

  <NoteCompletion
    pillar={progressPillar}
    slug={entry.id}
    title={fm.title}
    nextHref={nextHref}
    nextTitle={nextTitle}
  />

  {fm.prerequisites && fm.prerequisites.length > 0 && (
    <footer class="note__prereqs">
      <h4>Prerequisites</h4>
      <ul>
        {fm.prerequisites.map((slug) => (
          <li><a href={`${pillarRoute}/${slug}/`}>{slug}</a></li>
        ))}
      </ul>
    </footer>
  )}
</article>

<style>
  .note { max-width: 48rem; margin: 0 auto; }
  .note__crumbs {
    font-size: 0.85rem;
    color: var(--fg-muted);
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  .note__crumbs a { color: var(--fg-muted); }
  .note__head { margin-bottom: 2rem; }
  .note__title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0 0 0.75rem;
  }
  .note__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    color: var(--fg-muted);
    font-size: 0.85rem;
  }
  .note__minutes {
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    color: var(--primary-light);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-weight: 600;
  }
  .note__tags { display: inline-flex; gap: 0.3rem; flex-wrap: wrap; }
  .note__lock {
    background: var(--grad-5);
    color: white;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .note__summary {
    color: var(--fg-muted);
    margin: 1rem 0 0;
    font-style: italic;
    font-size: 1rem;
  }
  .note__body :global(h2),
  .note__body :global(h3),
  .note__body :global(h4) {
    position: relative;
    scroll-margin-top: 5.5rem;
  }
  .note__body :global(h2) { margin-top: 2.5rem; }
  .note__body :global(h3) { margin-top: 2rem; }

  /* Heading permalinks — rehype-autolink-headings appends a `¶` glyph to
     every heading; reveal it on hover/focus of the heading or anchor. */
  .note__body :global(.note__heading-anchor) {
    position: absolute;
    left: -1.5rem;
    top: 0;
    width: 1.5rem;
    height: 100%;
    display: inline-flex;
    align-items: center;
    color: var(--fg-faint);
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.15s ease, color 0.15s ease;
  }
  .note__body :global(h2:hover) .note__heading-anchor,
  .note__body :global(h3:hover) .note__heading-anchor,
  .note__body :global(h4:hover) .note__heading-anchor,
  .note__body :global(.note__heading-anchor:focus) { opacity: 1; }
  .note__body :global(.note__heading-anchor:hover) { color: var(--accent); }
  .note__body :global(.note__heading-anchor-glyph) {
    font-size: 0.85em;
    font-weight: 400;
  }
  .note__body :global(ul), .note__body :global(ol) {
    line-height: 1.7;
    padding-left: 1.5rem;
  }
  .note__body :global(blockquote) {
    border-left: 3px solid var(--primary);
    padding: 0.4rem 1rem;
    margin: 1.5rem 0;
    color: var(--fg-muted);
    background: color-mix(in srgb, var(--primary) 8%, transparent);
    border-radius: 0 6px 6px 0;
  }
  .note__prereqs {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--card-border);
  }
  .note__prereqs h4 { margin: 0 0 0.5rem; color: var(--fg-muted); font-weight: 600; }
  .note__prereqs ul { margin: 0; padding-left: 1.25rem; }
</style>
