---
import { getDb } from '~/lib/db';
import { canAccess } from '~/lib/billing/entitlement';
import Paywall from './Paywall.astro';

/**
 * Block-level premium gate. Authors wrap a region in:
 *
 *   <Premium key="proof-of-quorum">
 *     ...derivation...
 *   </Premium>
 *
 * Phase 1 was a pass-through. Phase 3 queries `entitlement_overrides` for
 * `block:<noteSlug>:<key>`: admin/paid → render children, free + gated →
 * render <Paywall reason="block" />. The key MUST be stable + locally
 * unique per file (plan §14f) — port-integrity vitest enforces this.
 */
interface Props {
  key: string;
}
const { key } = Astro.props;

const entry = Astro.locals.entry;
const noteSlug = entry?.id ?? 'unknown';
const blockEntityId = `${noteSlug}:${key}`;

const env = Astro.locals.runtime?.env;
const db = await getDb({ env });
const access = await canAccess(
  db,
  { kind: 'block', id: blockEntityId, defaultPremium: false },
  Astro.locals.user,
);
---
{access.allowed ? <slot /> : <Paywall reason="block" />}
