---
/**
 * Block-level premium gate placeholder.
 *
 * Phase 1 (this version): pass-through. Renders children unconditionally.
 * Phase 3: real entitlement check — for free tier + gated block, renders a
 *          <Paywall reason="block"/> instead. The `key` prop becomes the
 *          entity_id in the D1 `entitlement_overrides` table — that's why
 *          it must be stable + locally unique per file (plan §14f).
 *
 * Authors MUST supply an explicit `key`. A vitest enforces that every
 * <Premium> in src/content/** carries a non-empty, locally-unique key
 * before Phase 3 ships.
 */
interface Props {
  /** Stable block id. Becomes `block:<noteSlug>:<key>` in the override table. */
  key: string;
}
const { key } = Astro.props;
// Reference `key` so TS strict doesn't drop the unused-var lint — it's a
// contract field even though Phase 1 doesn't read it.
void key;
---
<slot />
