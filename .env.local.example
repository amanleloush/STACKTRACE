# Phase 3 (auth) — required for the Google OAuth flow.
# Get these from https://console.cloud.google.com/apis/credentials :
#   1. Create an OAuth 2.0 Client ID (Web application)
#   2. Authorized redirect URI: http://localhost:4321/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_URL=http://localhost:4321

# Comma-separated emails that auto-promote to role=admin on first sign-in.
# Plan §14h.
ADMIN_EMAILS=

# Dev-only OAuth bypass. Set to 1 to enable /api/auth/dev-login?email=... ,
# which mints a session against any email without going through Google.
# Refuses to run when import.meta.env.PROD is true.
DEV_AUTH_BACKDOOR=0
