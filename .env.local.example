# Phase 3 (auth) — required for the Google OAuth flow.
# Get these from https://console.cloud.google.com/apis/credentials :
#   1. Create an OAuth 2.0 Client ID (Web application)
#   2. Authorized redirect URI: http://localhost:4321/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_URL=http://localhost:4321

# Comma-separated emails that auto-promote to role=admin on first sign-in.
# Plan §14h.
ADMIN_EMAILS=

# Dev-only OAuth bypass. Set to 1 to enable /api/auth/dev-login?email=... ,
# which mints a session against any email without going through Google.
# Refuses to run when import.meta.env.PROD is true.
DEV_AUTH_BACKDOOR=0

# Phase 4 (Razorpay subscriptions). Grab these from the Razorpay test
# dashboard (https://dashboard.razorpay.com → Settings → API Keys, and
# Subscriptions → Plans for the plan id).
# Leave blank to run the subscription state machine in DEV without a
# Razorpay account — use /api/admin/dev/fake-razorpay-event to simulate.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
# Webhook signing secret — set this in the dashboard under Settings →
# Webhooks, then paste the secret here. Required for /api/razorpay/webhook
# to accept events in production.
RAZORPAY_WEBHOOK_SECRET=
