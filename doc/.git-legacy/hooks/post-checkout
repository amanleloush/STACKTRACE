#!/bin/bash

echo "Current branch: $(git rev-parse --abbrev-ref HEAD)"
if [ ! -f ".pre-commit-config.yaml" ]; then
    cat > ".pre-commit-config.yaml" <<EOC
repos:
  - repo: local
    hooks:
      - id: trufflehog
        name: TruffleHog
        description: Detect secrets in your data.
        entry: "pre-commit-scripts/runner.sh"
        language: script
        stages: ["pre-commit", "pre-push"]
  - repo: local
    hooks:
      - id: post-commit
        name: Post Commit
        description: Run post-commit scripts.
        entry: "post-commit-scripts/runner.sh"
        language: script
        stages: ["post-commit"]
        always_run: true
EOC
else
    if ! grep -q "id: trufflehog" ".pre-commit-config.yaml"; then
        if [ -s ".pre-commit-config.yaml" ] && [ "$(tail -c 1 ".pre-commit-config.yaml")" != "" ]; then
            echo "" >> ".pre-commit-config.yaml"
        fi
        cat >>".pre-commit-config.yaml" <<EOC
  - repo: local
    hooks:
      - id: trufflehog
        name: TruffleHog
        description: Detect secrets in your data.
        entry: "pre-commit-scripts/runner.sh"
        language: script
        stages: ["pre-commit", "pre-push"]
EOC
    else
        # Update existing entry if it has the old path
        if grep -q "entry:.*trufflehog/trufflehog-hook.sh" ".pre-commit-config.yaml"; then
            sed -i '' '/entry:.*trufflehog\/trufflehog-hook\.sh/s|entry:.*|entry: "pre-commit-scripts/runner.sh"|' ".pre-commit-config.yaml"
        fi
    fi
    if ! grep -q "id: post-commit" ".pre-commit-config.yaml"; then
        if [ -s ".pre-commit-config.yaml" ] && [ "$(tail -c 1 ".pre-commit-config.yaml")" != "" ]; then
            echo "" >> ".pre-commit-config.yaml"
        fi
        cat >>".pre-commit-config.yaml" <<EOC
  - repo: local
    hooks:
      - id: post-commit
        name: Post Commit
        description: Run post-commit scripts.
        entry: "post-commit-scripts/runner.sh"
        language: script
        stages: ["post-commit"]
        always_run: true
EOC
    fi
fi

# Handle folder renaming: if trufflehog exists, rename to pre-commit-scripts
if [ -d "trufflehog" ] && [ ! -d "pre-commit-scripts" ]; then
    echo "Renaming existing trufflehog folder to pre-commit-scripts..."
    mv trufflehog pre-commit-scripts
elif [ ! -d "pre-commit-scripts" ]; then
    mkdir -p pre-commit-scripts
fi

if [ ! -d "post-commit-scripts" ]; then
    mkdir -p post-commit-scripts
fi

scripts_dir="$HOME/.git-templates/pre-commit-scripts"
post_commit_dir="$HOME/.git-templates/post-commit-scripts"
# Check if old location exists and migrate
if [ -d "$HOME/.git-templates/trufflehog" ] && [ ! -d "$scripts_dir" ]; then
    echo "Migrating trufflehog folder to pre-commit-scripts in .git-templates..."
    mv "$HOME/.git-templates/trufflehog" "$scripts_dir"
fi

# Copy all required scripts into repo
if [ -d "$scripts_dir" ]; then
    if [ -f "$scripts_dir/trufflehog-hook.sh" ]; then
        cp "$scripts_dir/trufflehog-hook.sh" pre-commit-scripts/trufflehog-hook.sh
        chmod +x pre-commit-scripts/trufflehog-hook.sh
    fi
    if [ -f "$scripts_dir/cac-validate.sh" ]; then
        cp "$scripts_dir/cac-validate.sh" pre-commit-scripts/cac-validate.sh
        chmod +x pre-commit-scripts/cac-validate.sh
    fi
    if [ -f "$scripts_dir/yaakhook.sh" ]; then
        cp "$scripts_dir/yaakhook.sh" pre-commit-scripts/yaakhook.sh
        chmod +x pre-commit-scripts/yaakhook.sh
    fi
    if [ -f "$scripts_dir/runner.sh" ]; then
        cp "$scripts_dir/runner.sh" pre-commit-scripts/runner.sh
        chmod +x pre-commit-scripts/runner.sh
    fi
else
    echo "Pre-commit scripts directory not found at $scripts_dir"
fi

if [ -d "$post_commit_dir" ]; then
    if [ -f "$post_commit_dir/runner.sh" ]; then
        cp "$post_commit_dir/runner.sh" post-commit-scripts/runner.sh
        chmod +x post-commit-scripts/runner.sh
    fi
    if [ -f "$post_commit_dir/commit-metric.sh" ]; then
        cp "$post_commit_dir/commit-metric.sh" post-commit-scripts/commit-metric.sh
        chmod +x post-commit-scripts/commit-metric.sh
    fi
else
    echo "Post-commit scripts directory not found at $post_commit_dir"
fi

# Install pre-commit hooks
repo_root=$(git rev-parse --show-toplevel)
(cd "$repo_root" && pre-commit install --hook-type post-commit --hook-type pre-commit --allow-missing-config) || {
    echo "Failed to install pre-commit hooks in $repo_root. Skipping."
}