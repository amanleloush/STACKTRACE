{
  "name": "sysviz-next",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Interactive system-design and DSA visualizations. Working title — rename via SITE_SLUG.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node --experimental-strip-types --no-warnings scripts/migrate.ts",
    "port": "node --experimental-strip-types --no-warnings scripts/port-content.ts",
    "audit:links": "node --experimental-strip-types --no-warnings scripts/audit-links.ts",
    "audit:roadmap": "node --experimental-strip-types --no-warnings scripts/audit-roadmap.ts"
  },
  "dependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/cloudflare": "^12.6.4",
    "@astrojs/mdx": "4.0.3",
    "@astrojs/sitemap": "3.2.1",
    "astro": "5.1.1",
    "astro-pagefind": "1.8.3",
    "fuse.js": "7.0.0",
    "mermaid": "11.4.1",
    "pagefind": "1.2.0",
    "typescript": "5.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.10.2",
    "better-sqlite3": "^12.10.0",
    "vitest": "^4.1.7",
    "zod": "^3.25.76"
  }
}
